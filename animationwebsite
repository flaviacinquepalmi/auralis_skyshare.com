html = '''<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Auralis SkyShare — Private Aviation</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
<style>
:root{
  --navy:#0A1628;
  --navy2:#142140;
  --blue:#4A7BC4;
  --blue2:#6BAED6;
  --gold:#C9A535;
  --gold2:#E8C96A;
  --white:#FFFFFF;
  --offwhite:#F7F9FC;
  --gray:#EEF2F7;
  --text:#0A1628;
  --muted:#607080;
  --border:rgba(10,22,40,0.1);
  --border-gold:rgba(201,165,53,0.25);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Segoe UI',system-ui,-apple-system,sans-serif;background:#fff;color:var(--text);overflow-x:hidden}
.page{display:none;min-height:100vh;animation:pageIn .6s ease}
.page.active{display:block}
@keyframes pageIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(255,255,255,0.95);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);padding:0 48px;height:68px;display:flex;align-items:center;justify-content:space-between;transition:all .3s}
.nav-logo img{height:28px;object-fit:contain;filter:brightness(0) saturate(100%) invert(42%) sepia(60%) saturate(400%) hue-rotate(190deg) brightness(90%)}
.nav-menu{display:flex;gap:0;list-style:none}
.nav-menu li a{display:block;padding:8px 14px;font-size:12px;letter-spacing:.8px;text-transform:uppercase;color:var(--muted);text-decoration:none;font-weight:500;transition:color .2s;cursor:pointer;border:none;background:none}
.nav-menu li a:hover,.nav-menu li a.active{color:var(--navy)}
.nav-cta{background:var(--navy);color:#fff;border:none;padding:10px 24px;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;font-weight:700;cursor:pointer;transition:all .25s;white-space:nowrap}
.nav-cta:hover{background:var(--gold);color:var(--navy)}

/* ── HERO ── */
.hero-section{min-height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;position:relative;overflow:hidden;background:linear-gradient(170deg,#fff 0%,#F0F5FF 50%,#E8F0FA 100%);padding-top:68px}
.hero-sky{position:absolute;inset:0;background:linear-gradient(180deg,rgba(230,240,255,.6) 0%,rgba(255,255,255,.3) 60%,rgba(255,248,232,.4) 100%);pointer-events:none}
.hero-content{position:relative;z-index:10;text-align:center;max-width:760px;padding:0 32px}
.hero-eyebrow{font-size:10px;letter-spacing:4px;color:var(--gold);text-transform:uppercase;font-weight:700;margin-bottom:20px;display:flex;align-items:center;justify-content:center;gap:12px}
.hero-eyebrow::before,.hero-eyebrow::after{content:'';width:40px;height:1px;background:var(--gold)}
.hero-badge{display:inline-block;background:rgba(74,123,196,.08);border:1px solid rgba(74,123,196,.2);color:var(--blue);font-size:10px;letter-spacing:2px;padding:5px 16px;text-transform:uppercase;font-weight:700;margin-bottom:32px}
.hero-title{font-size:clamp(36px,5.5vw,68px);font-weight:900;line-height:1.0;letter-spacing:-2px;color:var(--navy);margin-bottom:10px}
.hero-title-gold{font-size:clamp(32px,4.5vw,56px);font-weight:800;color:var(--gold);letter-spacing:-1px;margin-bottom:32px;font-style:italic}
.hero-quote{font-size:16px;color:var(--muted);line-height:1.75;max-width:580px;margin:0 auto 20px;font-style:italic}
.hero-quote strong{color:var(--navy);font-style:normal;font-weight:700}
.hero-attr{font-size:11px;letter-spacing:2px;color:rgba(10,22,40,.35);text-transform:uppercase;margin-top:32px}
.hero-ctas{display:flex;gap:14px;justify-content:center;margin-top:40px;flex-wrap:wrap}
.btn-primary{background:var(--navy);color:#fff;border:none;padding:15px 36px;font-size:12px;letter-spacing:2px;text-transform:uppercase;font-weight:700;cursor:pointer;transition:all .25s}
.btn-primary:hover{background:var(--gold);color:var(--navy);transform:translateY(-2px)}
.btn-outline{background:transparent;color:var(--navy);border:1.5px solid var(--navy);padding:14px 32px;font-size:12px;letter-spacing:2px;text-transform:uppercase;font-weight:700;cursor:pointer;transition:all .25s}
.btn-outline:hover{background:var(--navy);color:#fff}

/* JET ANIMATION CANVAS */
.jet-scene{position:absolute;inset:0;pointer-events:none;overflow:hidden}
.animated-jet{position:absolute;pointer-events:none}

/* ── STATS BAR ── */
.stats-bar{background:var(--navy);padding:28px 56px;display:grid;grid-template-columns:repeat(4,1fr)}
.stat-i{text-align:center;padding:0 20px;border-right:1px solid rgba(255,255,255,.1)}
.stat-i:last-child{border-right:none}
.stat-n{font-size:30px;font-weight:900;color:var(--gold2);letter-spacing:-1px}
.stat-l{font-size:9px;letter-spacing:2px;color:rgba(255,255,255,.45);text-transform:uppercase;margin-top:5px}

/* ── SECTION COMMONS ── */
.section-wrap{max-width:1100px;margin:0 auto;padding:0 56px}
.section-eyebrow{font-size:10px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;font-weight:700;margin-bottom:12px;display:block}
.section-title{font-size:clamp(28px,3.8vw,48px);font-weight:900;letter-spacing:-1.5px;color:var(--navy);line-height:1.05;margin-bottom:16px}
.section-sub{font-size:15px;color:var(--muted);line-height:1.75;max-width:500px}

/* ── PAGE HERO BANDS ── */
.page-hero{height:52vh;min-height:360px;position:relative;overflow:hidden;display:flex;align-items:flex-end;padding-bottom:60px}
.page-hero-bg{position:absolute;inset:0;background:linear-gradient(160deg,var(--navy) 0%,var(--navy2) 60%,#1E3A6E 100%)}
.page-hero-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,transparent 40%,rgba(10,22,40,.6) 100%)}
.page-hero-content{position:relative;z-index:10;padding:0 56px}
.page-hero-content .section-eyebrow{color:var(--gold2)}
.page-hero-content .section-title{color:#fff;font-size:clamp(32px,5vw,64px)}

/* ── COME FUNZIONA ── */
.how-section{padding:100px 0;background:#fff}
.how-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:72px}
.how-step{background:var(--offwhite);border:1px solid var(--border);padding:44px 36px;position:relative;overflow:hidden;transition:all .4s;cursor:default}
.how-step:hover{border-color:var(--border-gold);background:#fff;transform:translateY(-6px);box-shadow:0 20px 60px rgba(10,22,40,.08)}
.how-step::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:linear-gradient(to right,var(--gold),var(--gold2));transform:scaleX(0);transition:transform .4s;transform-origin:left}
.how-step:hover::after{transform:scaleX(1)}
.step-n{font-size:56px;font-weight:900;color:rgba(10,22,40,.06);letter-spacing:-2px;margin-bottom:20px;line-height:1}
.step-icon{font-size:28px;margin-bottom:16px}
.step-title{font-size:18px;font-weight:800;color:var(--navy);margin-bottom:10px;letter-spacing:-.3px}
.step-desc{font-size:13px;color:var(--muted);line-height:1.75}
.cloud-anim{position:relative;height:200px;background:linear-gradient(180deg,#E8F0FA 0%,#D4E4F8 100%);overflow:hidden;margin:60px 0;display:flex;align-items:center;justify-content:center}
.cloud-text{font-size:14px;letter-spacing:3px;text-transform:uppercase;color:var(--blue);font-weight:600;position:relative;z-index:2}

/* ── EMPTY LEG ── */
.el-section{padding:100px 0;background:#fff}
.map-container{background:linear-gradient(135deg,var(--navy) 0%,#0E2040 100%);border-radius:0;padding:48px;margin:60px 0;position:relative;overflow:hidden;min-height:320px;display:flex;align-items:center}
.map-svg-wrap{width:100%;position:relative;z-index:2}
.el-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:48px}
.el-card{background:#fff;border:1px solid var(--border);padding:24px;transition:all .3s;cursor:pointer}
.el-card:hover{border-color:var(--border-gold);box-shadow:0 8px 32px rgba(10,22,40,.08);transform:translateY(-4px)}
.el-route-row{display:flex;align-items:center;gap:12px;margin-bottom:16px}
.el-iata{font-size:26px;font-weight:900;color:var(--navy);letter-spacing:-1px}
.el-arrow{flex:1;display:flex;align-items:center;gap:6px}
.el-line{flex:1;height:1px;background:linear-gradient(to right,var(--border),var(--gold),var(--border))}
.el-icon{color:var(--gold);font-size:14px}
.el-meta{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px}
.el-meta-item .v{font-size:13px;font-weight:700;color:var(--navy)}
.el-meta-item .k{font-size:9px;letter-spacing:1.5px;color:var(--muted);text-transform:uppercase;margin-top:2px}
.el-footer{display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--border);padding-top:14px}
.el-price{font-size:22px;font-weight:900;color:var(--gold)}
.el-save{font-size:10px;color:#2E9E60;letter-spacing:1px;background:rgba(46,158,96,.08);border:1px solid rgba(46,158,96,.2);padding:3px 8px;margin-top:3px}
.el-cd{font-size:11px;color:var(--muted);text-align:right}
.el-cd span{color:var(--navy);font-weight:700}
.el-btn{background:var(--navy);color:#fff;border:none;padding:8px 18px;font-size:10px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all .25s;margin-top:6px;display:block;width:100%}
.el-btn:hover{background:var(--gold);color:var(--navy)}

/* ── PARTNER ── */
.partner-section{padding:100px 0;background:var(--offwhite)}
.partner-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-top:60px}
.partner-card{background:#fff;border:1px solid var(--border);padding:48px 40px;transition:all .35s;cursor:default}
.partner-card:hover{border-color:var(--border-gold);box-shadow:0 12px 48px rgba(10,22,40,.07)}
.pc-icon{font-size:36px;margin-bottom:20px}
.pc-n{font-size:9px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;margin-bottom:10px;font-weight:700}
.pc-title{font-size:22px;font-weight:800;color:var(--navy);margin-bottom:12px;letter-spacing:-.3px}
.pc-desc{font-size:13px;color:var(--muted);line-height:1.8}
.pc-tags{display:flex;flex-wrap:wrap;gap:8px;margin-top:20px}
.pc-tag{font-size:10px;letter-spacing:1px;color:var(--blue);background:rgba(74,123,196,.08);border:1px solid rgba(74,123,196,.2);padding:4px 12px}
.interior-cinema{height:220px;background:linear-gradient(135deg,#1a2a40 0%,#0d1828 100%);margin:60px 0;display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative}
.interior-cinema-text{font-size:13px;letter-spacing:4px;color:rgba(201,165,53,.7);text-transform:uppercase;position:relative;z-index:2}

/* ── PILOT ── */
.pilot-section{padding:100px 0;background:#fff}
.pilot-hero{background:linear-gradient(135deg,var(--navy) 0%,#1a3560 100%);padding:72px 56px;margin:60px 0;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
.pilot-hero-text .section-eyebrow{color:var(--gold2)}
.pilot-hero-text .section-title{color:#fff;font-size:36px}
.pilot-hero-text p{color:rgba(255,255,255,.6);font-size:14px;line-height:1.8;margin-bottom:28px}
.offer-pills{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:28px}
.offer-pill{background:rgba(201,165,53,.12);border:1px solid rgba(201,165,53,.25);color:var(--gold2);font-size:11px;letter-spacing:1px;padding:6px 16px;font-weight:600}
.cockpit-anim{position:relative;background:linear-gradient(135deg,#0a1220 0%,#0d1e38 100%);height:260px;display:flex;align-items:center;justify-content:center;overflow:hidden}
.cockpit-lights{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;padding:20px;position:relative;z-index:2}
.ck-btn{width:32px;height:20px;border-radius:3px;animation:ckFlash var(--d) ease-in-out infinite var(--dl)}
@keyframes ckFlash{0%,100%{opacity:.3}50%{opacity:1}}
.cockpit-horizon{position:absolute;bottom:0;left:0;right:0;height:50%;background:linear-gradient(to bottom,transparent,rgba(74,123,196,.15));border-top:1px solid rgba(74,123,196,.2)}

/* ── PRENOTA ── */
.prenota-section{padding:100px 0;background:var(--offwhite)}
.prenota-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-top:60px}
.prenota-form-panel{background:#fff;border:1px solid var(--border);padding:56px 48px}
.prenota-info-panel{background:var(--navy);padding:56px 48px}
.form-group{margin-bottom:24px}
.form-label{font-size:10px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;font-weight:600;margin-bottom:8px;display:block}
.form-input{width:100%;background:var(--offwhite);border:1px solid var(--border);padding:13px 16px;font-size:14px;color:var(--navy);font-family:inherit;outline:none;transition:border-color .2s}
.form-input:focus{border-color:var(--gold)}
.form-select{width:100%;background:var(--offwhite);border:1px solid var(--border);padding:13px 16px;font-size:14px;color:var(--navy);font-family:inherit;outline:none;appearance:none;cursor:pointer;transition:border-color .2s}
.form-select:focus{border-color:var(--gold)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.submit-btn{width:100%;padding:16px;background:var(--navy);color:#fff;border:none;font-size:11px;letter-spacing:3px;text-transform:uppercase;font-weight:700;cursor:pointer;transition:all .3s;margin-top:8px}
.submit-btn:hover{background:var(--gold);color:var(--navy)}
.info-eyebrow{font-size:9px;letter-spacing:3px;color:var(--gold2);text-transform:uppercase;margin-bottom:24px;display:block}
.info-title{font-size:26px;font-weight:900;color:#fff;letter-spacing:-.5px;margin-bottom:20px}
.info-list{list-style:none;margin-bottom:32px}
.info-list li{font-size:13px;color:rgba(255,255,255,.6);padding:10px 0;border-bottom:1px solid rgba(255,255,255,.07);display:flex;align-items:center;gap:10px}
.info-list li::before{content:"✓";color:var(--gold);font-weight:900;font-size:11px;flex-shrink:0}

/* ── CONTATTI ── */
.contatti-section{padding:100px 0;background:#fff}
.contatti-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-top:60px}
.hangar-panel{background:linear-gradient(135deg,#0a1628 0%,#142140 100%);padding:56px 48px;position:relative;overflow:hidden;display:flex;flex-direction:column;justify-content:space-between;min-height:480px}
.hangar-jets{position:absolute;bottom:0;left:0;right:0;height:40%;background:linear-gradient(to top,rgba(201,165,53,.04) 0%,transparent 100%)}
.contact-panel{background:var(--offwhite);border:1px solid var(--border);padding:56px 48px}
.contact-item{display:flex;align-items:flex-start;gap:16px;padding:20px 0;border-bottom:1px solid var(--border)}
.ci-icon{width:40px;height:40px;background:rgba(74,123,196,.08);border:1px solid rgba(74,123,196,.15);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;margin-top:2px}
.ci-label{font-size:9px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:5px;display:block}
.ci-val{font-size:14px;color:var(--navy);font-weight:600}
.ci-sub{font-size:12px;color:var(--muted);margin-top:2px}

/* ── CONFIGURA ── */
.config-section{padding:100px 0;background:#fff}
.config-panel-grid{display:grid;grid-template-columns:3fr 2fr;gap:2px;margin-top:60px}
.config-left{background:var(--offwhite);border:1px solid var(--border);padding:52px 44px}
.config-right{background:var(--navy);padding:52px 44px}
.config-step{margin-bottom:36px}
.cs-label{font-size:9px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:10px}
.cs-label::before{content:attr(data-n);width:22px;height:22px;border:1px solid rgba(201,165,53,.3);display:flex;align-items:center;justify-content:center;font-size:9px;color:var(--gold);flex-shrink:0;border-radius:50%}
.cs-options{display:flex;flex-direction:column;gap:8px}
.cs-opt{background:#fff;border:1px solid var(--border);padding:13px 16px;cursor:pointer;transition:all .2s;text-align:left;display:flex;align-items:center;justify-content:space-between;font-family:inherit}
.cs-opt:hover,.cs-opt.active{border-color:rgba(201,165,53,.45);background:rgba(201,165,53,.04)}
.cs-opt .opt-check{color:var(--gold);font-weight:900;font-size:11px;opacity:0;transition:opacity .2s}
.cs-opt.active .opt-check{opacity:1}
.cs-opt-label{font-size:13px;color:var(--navy)}
.cs-opt-price{font-size:12px;color:var(--gold)}
.cfg-summary{position:sticky;top:88px}
.cfg-sum-eyebrow{font-size:9px;letter-spacing:3px;color:var(--gold2);text-transform:uppercase;margin-bottom:24px;display:block}
.cfg-sum-title{font-size:22px;font-weight:900;color:#fff;letter-spacing:-.3px;margin-bottom:28px}
.cfg-sum-items{margin-bottom:28px}
.cfg-sum-item{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.07)}
.cfg-dot{width:5px;height:5px;border-radius:50%;background:var(--gold);flex-shrink:0}
.cfg-item-text{font-size:12px;color:rgba(255,255,255,.55)}
.cfg-totals{border-top:1px solid rgba(255,255,255,.12);padding-top:20px;margin-bottom:24px}
.cfg-row{display:flex;justify-content:space-between;margin-bottom:10px}
.cfg-key{font-size:11px;color:rgba(255,255,255,.4)}
.cfg-val{font-size:12px;color:rgba(255,255,255,.8);font-weight:600}
.cfg-total-row{display:flex;justify-content:space-between;border-top:1px solid rgba(255,255,255,.12);padding-top:16px;margin-top:4px}
.cfg-total-label{font-size:10px;letter-spacing:2px;color:var(--gold);text-transform:uppercase}
.cfg-total-price{font-size:28px;font-weight:900;color:var(--gold2);letter-spacing:-1px}
.cfg-book-btn{width:100%;padding:16px;background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--navy);border:none;font-size:11px;letter-spacing:3px;text-transform:uppercase;font-weight:900;cursor:pointer;transition:all .25s;margin-top:4px}
.cfg-book-btn:hover{opacity:.9;transform:translateY(-1px)}

/* ── MEMBERSHIP MINI ── */
.mem-section{padding:80px 0;background:var(--navy)}
.mem-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:56px}
.mem-card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);padding:40px 32px;transition:all .35s;cursor:default}
.mem-card:hover{border-color:rgba(201,165,53,.3);background:rgba(255,255,255,.06)}
.mem-card.featured{background:rgba(201,165,53,.07);border-color:rgba(201,165,53,.25)}
.mem-tier{font-size:9px;letter-spacing:3px;color:var(--gold2);text-transform:uppercase;margin-bottom:12px}
.mem-name{font-size:26px;font-weight:900;color:#fff;letter-spacing:-1px;margin-bottom:4px}
.mem-price{font-size:32px;font-weight:900;color:var(--gold2);letter-spacing:-1.5px;margin-top:16px}
.mem-per{font-size:11px;color:rgba(255,255,255,.35);letter-spacing:1px;margin-bottom:16px}
.mem-divider{width:32px;height:1px;background:var(--gold);margin:20px 0}
.mem-features{list-style:none;margin-bottom:28px}
.mem-features li{font-size:12px;color:rgba(255,255,255,.5);padding:7px 0;border-bottom:1px solid rgba(255,255,255,.06);display:flex;align-items:center;gap:9px}
.mem-features li::before{content:"✓";color:var(--gold);font-weight:900;font-size:10px;flex-shrink:0}
.mem-btn{width:100%;padding:12px;background:transparent;border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.7);font-size:10px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all .25s}
.mem-card.featured .mem-btn{background:var(--gold);border-color:var(--gold);color:var(--navy);font-weight:700}
.mem-btn:hover{border-color:var(--gold);color:var(--gold)}

/* ── FOOTER ── */
footer{background:var(--navy2);padding:64px 56px 32px;border-top:1px solid rgba(255,255,255,.06)}
.footer-top{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;margin-bottom:56px}
.footer-logo img{height:24px;filter:brightness(0) invert(1);margin-bottom:16px}
.footer-desc{font-size:12px;color:rgba(255,255,255,.35);line-height:1.8;max-width:240px}
.footer-tagline{font-size:9px;letter-spacing:2.5px;color:var(--gold);text-transform:uppercase;margin-top:14px}
.footer-col h4{font-size:9px;letter-spacing:3px;color:rgba(255,255,255,.5);text-transform:uppercase;margin-bottom:18px;font-weight:700}
.footer-col a{display:block;font-size:12px;color:rgba(255,255,255,.3);text-decoration:none;margin-bottom:10px;transition:color .2s;cursor:pointer}
.footer-col a:hover{color:var(--gold2)}
