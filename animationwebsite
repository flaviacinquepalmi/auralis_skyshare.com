<script>
const LOGO = "Auralis%20Logo.png";

// ── PAGE ROUTER ──────────────────────────────────────────────────────────────
const pages = ['home','come-funziona','empty-leg','partner','pilot','prenota','configura','contatti'];
function showPage(id) {
  pages.forEach(p => {
    const el = document.getElementById('page-'+p);
    const nav = document.getElementById('nav-'+p);
    if(el) el.classList.toggle('active', p===id);
    if(nav) nav.classList.toggle('active', p===id);
  });
  // Show footer on all pages except home (home has its own bottom section)
  const footer = document.getElementById('main-footer');
  if(footer) footer.style.display = id==='home' ? 'none' : 'block';
  window.scrollTo({top:0,behavior:'smooth'});
  // Trigger reveal animations
  setTimeout(()=>{
    document.querySelectorAll('#page-'+id+' .fade-up').forEach(el=>{
      el.classList.remove('visible');
      setTimeout(()=>el.classList.add('visible'),50);
    });
  },100);
  // Re-run landing jet animation on prenota page
  if(id==='prenota'){
    const lj = document.getElementById('landing-hero-jet');
    if(lj){ lj.style.animation='none'; setTimeout(()=>{ lj.style.animation='jetLand 4s cubic-bezier(.25,.46,.45,.94) forwards 0.5s'; },50); }
  }
}

// ── HERO JET ANIMATION ───────────────────────────────────────────────────────
const heroJet = document.getElementById('landing-jet');
const contrail = document.getElementById('contrail');
function flyHeroJet(){
  if(!heroJet) return;
  heroJet.style.opacity='0';
  heroJet.style.right='-200px';
  contrail.style.opacity='0';
  setTimeout(()=>{
    gsap.fromTo(heroJet,
      {right:'-200px',top:'18%',opacity:0,rotation:-4,scale:.7},
      {right:'calc(100% + 50px)',top:'20%',opacity:[0,1,1,0],rotation:2,scale:1,duration:6,ease:'power1.inOut',
        onStart:()=>{ gsap.to(contrail,{opacity:.5,duration:.5,delay:.3}); },
        onComplete:()=>{
          gsap.to(contrail,{opacity:0,duration:1});
          setTimeout(flyHeroJet, 8000);
        }
      }
    );
  },500);
}
setTimeout(flyHeroJet, 1200);

// ── SCROLL REVEAL ────────────────────────────────────────────────────────────
const revObs = new IntersectionObserver(entries=>{
  entries.forEach(e=>{ if(e.isIntersecting) e.target.classList.add('visible'); });
},{threshold:.08});
document.querySelectorAll('.fade-up').forEach(el=>revObs.observe(el));

// ── NAV SCROLL ───────────────────────────────────────────────────────────────
window.addEventListener('scroll',()=>{
  const nav=document.getElementById('mainnav');
  nav.style.boxShadow = window.scrollY>40 ? '0 2px 24px rgba(10,22,40,.08)' : 'none';
});

// ── COUNTDOWNS ───────────────────────────────────────────────────────────────
function startTimer(id,h,m,s){
  let t=h*3600+m*60+s;
  setInterval(()=>{
    t=Math.max(0,t-1);
    const hh=String(Math.floor(t/3600)).padStart(2,'0');
    const mm=String(Math.floor((t%3600)/60)).padStart(2,'0');
    const ss=String(t%60).padStart(2,'0');
    const el=document.getElementById(id);
    if(el) el.textContent=hh+':'+mm+':'+ss;
  },1000);
}
startTimer('cd1',4,32,18);
startTimer('cd2',11,8,44);
startTimer('cd3',7,55,22);

// ── CONFIGURATOR ─────────────────────────────────────────────────────────────
const cfgRates = {jet:7200, catering:800, ground:1200};
function cfgSelect(btn, cat, label, priceStr){
  const price = parseInt(priceStr);
  btn.closest('.cs-options').querySelectorAll('.cs-opt').forEach(b=>{
    b.classList.remove('active');
    b.querySelector('.opt-check').style.opacity='0';
  });
  btn.classList.add('active');
  btn.querySelector('.opt-check').style.opacity='1';
  cfgRates[cat] = price;
  cfgUpdateTotal();
}
function cfgUpdateTotal(){
  const hrs=3;
  const a=cfgRates.jet*hrs, c=cfgRates.catering, g=cfgRates.ground;
  const fmt=n=>'€'+n.toLocaleString('it-IT');
  const ja=document.getElementById('cfg-t-jet');
  const ca=document.getElementById('cfg-t-cat');
  const ga=document.getElementById('cfg-t-gnd');
  const ta=document.getElementById('cfg-t-total');
  if(ja) ja.textContent=fmt(a);
  if(ca) ca.textContent=fmt(c);
  if(ga) ga.textContent=fmt(g);
  if(ta) ta.textContent=fmt(a+c+g);
}

// ── GSAP scroll micro-animations ─────────────────────────────────────────────
gsap.registerPlugin(ScrollTrigger);
// Subtle parallax on page heroes
document.querySelectorAll('.page-hero-bg').forEach(el=>{
  gsap.to(el,{
    yPercent:-20,
    ease:'none',
    scrollTrigger:{trigger:el.parentElement,start:'top top',end:'bottom top',scrub:true}
  });
});
// Stats counter on home
document.querySelectorAll('.stat-n').forEach(el=>{
  const txt=el.textContent;
  if(!txt.includes('+')||txt.includes('€')||txt.includes('%')) return;
  const num=parseInt(txt);
  ScrollTrigger.create({
    trigger:el,start:'top 90%',once:true,
    onEnter:()=>{
      let cur=0;
      const step=num/50;
      const t=setInterval(()=>{
        cur=Math.min(cur+step,num);
        el.textContent=Math.floor(cur)+'+';
        if(cur>=num) clearInterval(t);
      },20);
    }
  });
});

// Show home footer
document.getElementById('main-footer') && (document.getElementById('main-footer').style.display='none');
</script>
</body>
</html>'''
