bash

cat > /mnt/user-data/outputs/auralis_skyshare.html << 'HTMLEOF'
<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Auralis – The Smart Way to Fly Private</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --navy:#0D1F3C;
  --navy2:#162A4A;
  --gold:#C9A535;
  --gold2:#E8C96A;
  --skyblue:#6BAED6;
  --skyblue2:#A8D4F0;
  --white:#FFFFFF;
  --offwhite:#F5F8FC;
  --gray:#EEF2F7;
  --text:#0D1F3C;
  --muted:#556070;
  --r:14px;
}
html{scroll-behavior:smooth}
body{font-family:'Segoe UI',system-ui,-apple-system,sans-serif;background:#fff;color:var(--text);overflow-x:hidden}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:20px 56px;background:rgba(255,255,255,0.94);backdrop-filter:blur(16px);border-bottom:1px solid rgba(201,165,53,0.12);transition:padding .3s,box-shadow .3s}
nav.scrolled{padding:13px 56px;box-shadow:0 4px 32px rgba(13,31,60,0.08)}
.logo{display:flex;align-items:center;gap:11px;text-decoration:none}
.logo-mark{position:relative;width:38px;height:38px}
.logo-mark svg{width:38px;height:38px}
.logo-text{font-size:24px;font-weight:800;letter-spacing:-0.5px;color:var(--navy)}
.logo-text span{color:var(--gold)}
.nav-links{display:flex;gap:36px;list-style:none}
.nav-links a{text-decoration:none;color:var(--muted);font-size:14px;font-weight:500;letter-spacing:.2px;transition:color .2s}
.nav-links a:hover{color:var(--navy)}
.nav-actions{display:flex;gap:12px;align-items:center}
.nav-btn-ghost{background:transparent;color:var(--navy);border:1.5px solid rgba(13,31,60,0.18);padding:9px 22px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s}
.nav-btn-ghost:hover{border-color:var(--gold);color:var(--gold)}
.nav-btn-solid{background:var(--navy);color:#fff;border:none;padding:10px 24px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s}
.nav-btn-solid:hover{background:var(--gold);transform:translateY(-1px)}

/* HERO */
.hero{min-height:100vh;background:linear-gradient(150deg,#08152B 0%,#0D1F3C 35%,#122944 55%,#1B3D60 75%,#254E7A 100%);position:relative;overflow:hidden;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:120px 56px 80px}
#stars-layer{position:absolute;inset:0;pointer-events:none}
.s{position:absolute;background:#fff;border-radius:50%;animation:tw var(--d) ease-in-out infinite var(--dl)}
@keyframes tw{0%,100%{opacity:.05}50%{opacity:.85}}
.atm1{position:absolute;bottom:-60px;left:-10%;right:-10%;height:340px;background:radial-gradient(ellipse at 50% 100%, rgba(107,174,214,0.18) 0%, transparent 65%);pointer-events:none}
.atm2{position:absolute;bottom:-40px;left:0;right:0;height:180px;background:linear-gradient(to top,rgba(201,165,53,0.08) 0%,transparent 100%);pointer-events:none}

/* Intro jet */
#jet-fly{position:absolute;z-index:30;bottom:38%;left:-220px;animation:jetIntro 3.6s cubic-bezier(.22,.68,0,1.2) forwards}
@keyframes jetIntro{
  0%{left:-220px;bottom:35%;transform:scale(.65) rotate(-4deg);opacity:0}
  8%{opacity:1}
  55%{bottom:44%;transform:scale(1.05) rotate(-1.5deg)}
  85%{bottom:46%;transform:scale(1) rotate(0deg);opacity:1}
  100%{left:108%;bottom:46%;transform:scale(.75) rotate(2deg);opacity:0}
}
.jet-body{width:200px;filter:drop-shadow(0 6px 28px rgba(201,165,53,.55))}
#contrail{position:absolute;z-index:29;height:1.5px;left:80px;bottom:calc(44% + 26px);width:0;opacity:0;background:linear-gradient(to right,transparent,rgba(255,255,255,.7) 20%,rgba(255,255,255,.3) 80%,transparent);border-radius:2px;animation:cTrail 3.6s cubic-bezier(.22,.68,0,1.2) forwards;pointer-events:none}
@keyframes cTrail{
  0%{width:0;opacity:0;left:80px}
  10%{opacity:.8}
  55%{width:55vw;opacity:.55;left:0}
  100%{width:108vw;opacity:0;left:0}
}

/* Hero content */
.hero-inner{position:relative;z-index:20;text-align:center;max-width:860px;opacity:0;animation:upIn .9s ease forwards 3.2s}
@keyframes upIn{from{opacity:0;transform:translateY(36px)}to{opacity:1;transform:translateY(0)}}
.hero-eyebrow{display:inline-flex;align-items:center;gap:8px;background:rgba(201,165,53,.12);border:1px solid rgba(201,165,53,.35);color:var(--gold2);padding:7px 18px;border-radius:100px;font-size:11px;font-weight:700;letter-spacing:1.4px;text-transform:uppercase;margin-bottom:30px}
.hero-eyebrow::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--gold2);animation:dot 1.8s ease-in-out infinite}
@keyframes dot{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.6);opacity:.5}}
.hero h1{font-size:clamp(42px,6vw,80px);font-weight:900;color:#fff;line-height:1.03;letter-spacing:-2.5px;margin-bottom:22px}
.hero h1 .hl{background:linear-gradient(90deg,var(--gold),var(--gold2),#fff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-sub{font-size:18px;color:rgba(255,255,255,.62);line-height:1.65;max-width:560px;margin:0 auto 48px}
.hero-sub strong{color:rgba(255,255,255,.9);font-weight:600}
.hero-actions{display:flex;gap:14px;justify-content:center;flex-wrap:wrap}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--navy);border:none;padding:17px 40px;border-radius:10px;font-size:16px;font-weight:700;cursor:pointer;transition:all .25s;box-shadow:0 8px 32px rgba(201,165,53,.38);letter-spacing:.2px}
.btn-gold:hover{transform:translateY(-3px);box-shadow:0 14px 42px rgba(201,165,53,.52)}
.btn-ghost-white{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.28);padding:17px 40px;border-radius:10px;font-size:16px;font-weight:600;cursor:pointer;transition:all .25s}
.btn-ghost-white:hover{border-color:rgba(255,255,255,.65);background:rgba(255,255,255,.07)}
.hero-stats{position:relative;z-index:20;display:flex;border-top:1px solid rgba(255,255,255,.1);margin-top:72px;padding-top:44px;width:100%;max-width:740px;opacity:0;animation:upIn .8s ease forwards 3.8s}
.hstat{flex:1;text-align:center;padding:0 20px}
.hstat:not(:last-child){border-right:1px solid rgba(255,255,255,.1)}
.hstat-n{font-size:34px;font-weight:900;color:var(--gold2);letter-spacing:-1px;line-height:1}
.hstat-l{font-size:11px;color:rgba(255,255,255,.48);text-transform:uppercase;letter-spacing:1px;margin-top:6px}

/* PROBLEM */
.problem{background:var(--offwhite);padding:80px 56px;text-align:center}
.prob-title{font-size:clamp(26px,3.2vw,42px);font-weight:900;color:var(--navy);letter-spacing:-1px;line-height:1.1;margin-bottom:16px}
.prob-title em{font-style:normal;color:var(--gold)}
.prob-sub{font-size:16px;color:var(--muted);max-width:600px;margin:0 auto 52px;line-height:1.7}
.prob-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;max-width:900px;margin:0 auto}
.prob-card{background:#fff;border:1px solid rgba(13,31,60,.07);border-radius:16px;padding:28px 24px;transition:all .3s}
.prob-card:hover{border-color:rgba(201,165,53,.3);transform:translateY(-4px);box-shadow:0 12px 36px rgba(13,31,60,.07)}
.prob-num{font-size:44px;font-weight:900;color:var(--gold);letter-spacing:-2px;line-height:1}
.prob-unit{font-size:13px;color:var(--muted);margin:4px 0 10px;font-weight:500}
.prob-desc{font-size:13px;color:var(--muted);line-height:1.6}

/* HOW */
.how{padding:100px 56px;background:#fff}
.section-eyebrow{font-size:11px;font-weight:700;color:var(--gold);letter-spacing:2px;text-transform:uppercase;margin-bottom:10px;display:block}
.section-title{font-size:clamp(28px,3.5vw,46px);font-weight:900;color:var(--navy);letter-spacing:-1.2px;line-height:1.08;margin-bottom:14px}
.section-sub{font-size:16px;color:var(--muted);line-height:1.7}
.how-inner{max-width:1080px;margin:0 auto}
.how-head{text-align:center;margin-bottom:72px}
.how-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:0;position:relative}
.how-steps::before{content:'';position:absolute;top:52px;left:16.6%;right:16.6%;height:1.5px;background:linear-gradient(to right,transparent,rgba(201,165,53,.4),rgba(201,165,53,.4),transparent)}
.step{text-align:center;padding:0 32px;position:relative}
.step-circle{width:104px;height:104px;border-radius:50%;background:linear-gradient(135deg,var(--navy),var(--navy2));border:3px solid rgba(201,165,53,.25);display:flex;align-items:center;justify-content:center;margin:0 auto 28px;position:relative;transition:all .3s}
.step:hover .step-circle{border-color:var(--gold);transform:scale(1.05);box-shadow:0 8px 32px rgba(201,165,53,.3)}
.step-circle svg{width:38px;height:38px;stroke:#fff;fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round}
.step-n{position:absolute;top:-6px;right:-6px;width:28px;height:28px;background:var(--gold);border-radius:50%;font-size:12px;font-weight:800;color:var(--navy);display:flex;align-items:center;justify-content:center}
.step-title{font-size:18px;font-weight:700;color:var(--navy);margin-bottom:10px}
.step-desc{font-size:14px;color:var(--muted);line-height:1.65}

/* VALUE */
.value{background:var(--gray);padding:100px 56px}
.value-inner{max-width:1080px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center}
.value-pills{display:flex;flex-wrap:wrap;gap:10px;margin-top:24px}
.pill{display:inline-flex;align-items:center;gap:7px;background:#fff;border:1px solid rgba(13,31,60,.1);border-radius:100px;padding:8px 18px;font-size:13px;font-weight:600;color:var(--navy);transition:all .2s}
.pill:hover{border-color:var(--gold);color:var(--gold)}
.pill::before{content:'✓';color:var(--gold);font-weight:800}
.value-jets{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.jet-float-card{background:linear-gradient(135deg,var(--navy) 0%,var(--navy2) 100%);border-radius:18px;padding:24px 20px;position:relative;overflow:hidden;cursor:pointer;transition:all .35s;animation:fc var(--fd) ease-in-out infinite}
.jet-float-card:hover{transform:translateY(-10px) !important;box-shadow:0 20px 56px rgba(13,31,60,.22)}
@keyframes fc{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
.jet-float-card::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 20% 80%,rgba(201,165,53,.12) 0%,transparent 60%)}
.jfc-svg{display:flex;justify-content:center;margin-bottom:16px}
.jfc-svg svg{width:90px;filter:drop-shadow(0 3px 12px rgba(201,165,53,.45));animation:jg var(--jd) ease-in-out infinite}
@keyframes jg{0%,100%{transform:rotate(-2deg) translateY(0)}50%{transform:rotate(1deg) translateY(-4px)}}
.jfc-name{font-size:14px;font-weight:700;color:#fff;margin-bottom:4px}
.jfc-range{font-size:11px;color:var(--gold2)}
.jfc-badge{position:absolute;top:12px;right:12px;background:rgba(201,165,53,.2);border:1px solid rgba(201,165,53,.4);color:var(--gold2);font-size:9px;font-weight:700;padding:3px 8px;border-radius:100px;letter-spacing:.7px;text-transform:uppercase}

/* EMPTY LEG */
.emptyleg{background:linear-gradient(135deg,var(--navy) 0%,#0A1A33 100%);padding:90px 56px;position:relative;overflow:hidden}
.emptyleg::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E")}
.el-inner{max-width:1080px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center;position:relative;z-index:2}
.el-text .section-eyebrow{color:var(--gold2)}
.el-text .section-title{color:#fff}
.el-text .section-sub{color:rgba(255,255,255,.62);margin-bottom:32px}
.el-stat-row{display:flex;gap:32px}
.el-stat{border-left:2px solid var(--gold);padding-left:16px}
.el-stat-n{font-size:28px;font-weight:900;color:var(--gold2);letter-spacing:-1px}
.el-stat-l{font-size:11px;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.8px;margin-top:2px}
.el-visual{display:flex;flex-direction:column;gap:14px}
.route-card{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:20px 24px;display:flex;align-items:center;gap:20px;transition:all .3s;cursor:pointer}
.route-card:hover{background:rgba(255,255,255,.1);border-color:rgba(201,165,53,.3)}
.route-airports{display:flex;align-items:center;gap:12px;flex:1}
.airport-code{font-size:22px;font-weight:900;color:#fff;letter-spacing:-0.5px}
.route-arrow{flex:1;display:flex;align-items:center;gap:6px}
.r-line{flex:1;height:1px;background:linear-gradient(to right,rgba(255,255,255,.2),rgba(201,165,53,.5),rgba(255,255,255,.2))}
.r-plane{font-size:16px}
.route-price{text-align:right}
.r-price{font-size:18px;font-weight:800;color:var(--gold2)}
.r-from{font-size:10px;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:.8px}
.r-tag{background:rgba(46,158,97,.2);border:1px solid rgba(46,158,97,.4);color:#6EC89A;font-size:9px;font-weight:700;padding:2px 8px;border-radius:100px;letter-spacing:.7px;text-transform:uppercase;margin-top:4px;text-align:right}

/* PILOT */
.pilot{background:#fff;padding:90px 56px}
.pilot-inner{max-width:1080px;margin:0 auto}
.pilot-head{text-align:center;margin-bottom:60px}
.pilot-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.pilot-card{border-radius:18px;padding:36px 32px;border:1px solid transparent;transition:all .3s}
.pilot-card.dark{background:var(--navy);border-color:rgba(201,165,53,.15)}
.pilot-card.light{background:var(--offwhite);border-color:rgba(13,31,60,.07)}
.pilot-card:hover{transform:translateY(-4px);box-shadow:0 16px 48px rgba(13,31,60,.1)}
.pilot-icon{width:56px;height:56px;border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:22px}
.pilot-card.dark .pilot-icon{background:rgba(201,165,53,.15)}
.pilot-card.light .pilot-icon{background:rgba(13,31,60,.07)}
.pilot-icon svg{width:28px;height:28px;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round;fill:none}
.pilot-card.dark .pilot-icon svg{stroke:var(--gold2)}
.pilot-card.light .pilot-icon svg{stroke:var(--navy)}
.pilot-card-title{font-size:20px;font-weight:800;margin-bottom:10px;letter-spacing:-.3px}
.pilot-card.dark .pilot-card-title{color:#fff}
.pilot-card.light .pilot-card-title{color:var(--navy)}
.pilot-card p{font-size:14px;line-height:1.65}
.pilot-card.dark p{color:rgba(255,255,255,.6)}
.pilot-card.light p{color:var(--muted)}
.tag-row{display:flex;flex-wrap:wrap;gap:8px;margin-top:20px}
.tag{display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:600;padding:5px 12px;border-radius:100px}
.tag-gold{background:rgba(201,165,53,.15);color:var(--gold2);border:1px solid rgba(201,165,53,.3)}
.tag-navy{background:rgba(13,31,60,.07);color:var(--navy);border:1px solid rgba(13,31,60,.1)}

/* CTA */
.cta-band{background:linear-gradient(135deg,var(--gold) 0%,#E8C96A 50%,#F0D480 100%);padding:80px 56px;text-align:center;position:relative;overflow:hidden}
.cta-band::before{content:'';position:absolute;inset:0;opacity:.05;background:repeating-linear-gradient(45deg,#000 0,#000 1px,transparent 0,transparent 50%) 0/20px 20px}
.cta-band h2{font-size:clamp(28px,3.8vw,50px);font-weight:900;color:var(--navy);letter-spacing:-1.5px;margin-bottom:14px;position:relative}
.cta-band p{font-size:17px;color:rgba(13,31,60,.7);margin-bottom:36px;position:relative}
.btn-navy{background:var(--navy);color:#fff;border:none;padding:17px 44px;border-radius:10px;font-size:16px;font-weight:700;cursor:pointer;transition:all .25s;position:relative}
.btn-navy:hover{transform:translateY(-3px);box-shadow:0 12px 36px rgba(13,31,60,.3)}
.contact-row{display:flex;justify-content:center;gap:40px;margin-top:28px;position:relative}
.contact-item{display:flex;align-items:center;gap:8px;font-size:14px;color:rgba(13,31,60,.65);font-weight:500}
.contact-item svg{width:16px;height:16px;stroke:var(--navy);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}

/* FOOTER */
footer{background:var(--navy);padding:64px 56px 32px}
.footer-top{display:grid;grid-template-columns:2.2fr 1fr 1fr 1fr;gap:48px;margin-bottom:52px}
.footer-brand-desc{font-size:13px;color:rgba(255,255,255,.48);line-height:1.75;margin-top:18px;max-width:280px}
.footer-tagline{font-size:11px;color:var(--gold2);font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-top:12px}
.footer-col h4{font-size:11px;font-weight:700;color:rgba(255,255,255,.9);text-transform:uppercase;letter-spacing:1.2px;margin-bottom:22px}
.footer-col a{display:block;font-size:13px;color:rgba(255,255,255,.45);text-decoration:none;margin-bottom:11px;transition:color .2s}
.footer-col a:hover{color:var(--gold2)}
.footer-bottom{border-top:1px solid rgba(255,255,255,.08);padding-top:28px;display:flex;justify-content:space-between;align-items:center;font-size:12px;color:rgba(255,255,255,.3)}
.footer-bottom a{color:rgba(255,255,255,.3);text-decoration:none;margin-left:20px;transition:color .2s}
.footer-bottom a:hover{color:var(--gold2)}

/* SCROLL REVEAL */
.rv{opacity:0;transform:translateY(32px);transition:opacity .7s ease,transform .7s ease}
.rv.vis{opacity:1;transform:translateY(0)}
.rv2{opacity:0;transform:translateY(32px);transition:opacity .7s .15s ease,transform .7s .15s ease}
.rv2.vis{opacity:1;transform:translateY(0)}
.rv3{opacity:0;transform:translateY(32px);transition:opacity .7s .3s ease,transform .7s .3s ease}
.rv3.vis{opacity:1;transform:translateY(0)}
</style>
</head>
<body>

<nav id="mainnav">
  <a href="#" class="logo">
    <div class="logo-mark">
      <svg viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="38" height="38" rx="9" fill="#0D1F3C"/>
        <ellipse cx="19" cy="24" rx="14" ry="3" fill="none" stroke="#C9A535" stroke-width="1.5" opacity=".6"/>
        <path d="M19 8 C14 8 10 12 10 17 L19 30 L28 17 C28 12 24 8 19 8Z" fill="white" opacity=".9"/>
        <path d="M19 8 C22 8 25 10 26.5 13" stroke="#C9A535" stroke-width="1.8" stroke-linecap="round"/>
        <circle cx="26" cy="10" r="1.5" fill="#C9A535"/>
        <circle cx="29" cy="8" r="1" fill="#E8C96A" opacity=".7"/>
      </svg>
    </div>
    <span class="logo-text">AUR<span>A</span>LIS</span>
  </a>
  <ul class="nav-links">
    <li><a href="#how">Come Funziona</a></li>
    <li><a href="#emptyleg">Empty Leg</a></li>
    <li><a href="#pilot">Partner Program</a></li>
    <li><a href="#cta">Contatti</a></li>
  </ul>
  <div class="nav-actions">
    <button class="nav-btn-ghost">Sono un Operatore</button>
    <button class="nav-btn-solid">Prenota Ora</button>
  </div>
</nav>

<section class="hero">
  <div id="stars-layer"></div>
  <div class="atm1"></div>
  <div class="atm2"></div>

  <div id="jet-fly">
    <svg class="jet-body" viewBox="0 0 240 78" xmlns="http://www.w3.org/2000/svg">
      <defs><filter id="jglow"><feGaussianBlur stdDeviation="2.5" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter></defs>
      <g filter="url(#jglow)">
        <ellipse cx="123" cy="39" rx="108" ry="13" fill="#F0F8FF"/>
        <path d="M229 39 Q242 39 240 35 Q233 24 216 30 L229 39Z" fill="#E0F0FA"/>
        <path d="M17 39 Q4 39 4 36 L17 39Z" fill="#D0E4F4"/>
        <path d="M138 37 L172 8 L185 11 L160 37Z" fill="#C9A535"/>
        <path d="M138 41 L172 70 L185 67 L160 41Z" fill="#B89020"/>
        <path d="M138 33 L165 18 L172 20 L148 33Z" fill="#E8C96A" opacity=".5"/>
