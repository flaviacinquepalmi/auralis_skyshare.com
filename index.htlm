<script>
// Stars
const sl = document.getElementById('stars-layer');
for(let i=0;i<90;i++){
  const s=document.createElement('div');
  s.className='s';
  const sz=Math.random()*2.5+.5;
  s.style.cssText='width:'+sz+'px;height:'+sz+'px;left:'+Math.random()*100+'%;top:'+Math.random()*100+'%;--d:'+(1.8+Math.random()*4)+'s;--dl:-'+(Math.random()*4)+'s';
  sl.appendChild(s);
}

// Nav scroll
window.addEventListener('scroll',function(){
  document.getElementById('mainnav').classList.toggle('scrolled',window.scrollY>60);
});

// Scroll reveal
const obs=new IntersectionObserver(function(entries){
  entries.forEach(function(e){if(e.isIntersecting)e.target.classList.add('vis');});
},{threshold:0.1});
document.querySelectorAll('.rv,.rv2,.rv3').forEach(function(el){obs.observe(el);});
</script>
</body>
</html>
