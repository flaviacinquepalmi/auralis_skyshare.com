<script>
gsap.registerPlugin(ScrollTrigger);

// ── LOGO SRC (for GitHub: replace with "Auralis Logo.png") ────────────────
// Currently embedded as base64 for standalone use.

// ── PAGE ROUTER ──────────────────────────────────────────────────────────────
const ALL_PAGES = ['home','about','emptyleg','prenota','contatti','partner','pilot'];
const NAV_VISIBLE = ['home','about','emptyleg','prenota','contatti'];
const NAV_IDS = {home:'nl-home',about:'nl-about',emptyleg:'nl-emptyleg',prenota:'nl-prenota',contatti:'nl-contatti'};

function showPage(id) {
  ALL_PAGES.forEach(p => {
    const el = document.getElementById('page-'+p);
    if(el) el.classList.toggle('active', p===id);
  });
  // Update nav active link
  Object.entries(NAV_IDS).forEach(([p,nid]) => {
    const el = document.getElementById(nid);
    if(el) el.classList.toggle('active-link', p===id);
  });
  // Show/hide footer (hide on prenota — form is full-height)
  const footer = document.getElementById('main-footer');
  if(footer) footer.style.display = (id==='prenota') ? 'none' : 'block';
  window.scrollTo({top:0,behavior:'smooth'});
  // Trigger animations for the new page
  setTimeout(()=>{
    document.querySelectorAll('#page-'+id+' .fu').forEach(el=>{
      el.classList.remove('vis');
      void el.offsetWidth;
      setTimeout(()=>el.classList.add('vis'),60);
    });
    if(id==='contatti') flyContJet();
    if(id==='home') initRunwayJet();
    if(id==='prenota') initPrenotaScroll();
  },80);
}

// ── MODALS ───────────────────────────────────────────────────────────────────
function openOperatorModal(){ document.getElementById('operator-modal').classList.add('open'); }
function closeOperatorModal(){ document.getElementById('operator-modal').classList.remove('open'); }
function openReservedModal(){ document.getElementById('reserved-modal').classList.add('open'); }
function closeReservedModal(){ document.getElementById('reserved-modal').classList.remove('open'); }
function switchResTab(tab, btn){
  ['login','register','history'].forEach(t => document.getElementById('res-'+t).style.display = t===tab ? 'block' : 'none');
  document.querySelectorAll('.res-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

// ── RUNWAY JET ANIMATION (home) ───────────────────────────────────────────────
function initRunwayJet(){
  const jet = document.getElementById('runway-jet');
  if(!jet) return;
  // Start: high in the sky on the right, land on runway
  gsap.fromTo(jet,
    {right:'-280px', top:'5%', rotation:5, scale:.65, opacity:0},
    {right:'18%', top:'52%', rotation:0, scale:1, opacity:1, duration:4.5,
     ease:'power2.inOut',
     onComplete:()=>{
       // Taxi to the left slowly
       gsap.to(jet, {right:'60%', top:'55%', rotation:-1, duration:3, ease:'power1.inOut',
         onComplete:()=>{
           // Take off again
           gsap.to(jet, {right:'110%', top:'15%', rotation:-4, scale:.6, opacity:0, duration:3.5, ease:'power2.in',
             onComplete:()=>{ setTimeout(initRunwayJet, 4000); }
           });
         }
       });
     }
    }
  );
}

// ── SCROLL: runway jet follows scroll ────────────────────────────────────────
ScrollTrigger.create({
  trigger:'#hero-section', start:'top top', end:'bottom top', scrub:true,
  onUpdate:(self)=>{
    const jet = document.getElementById('runway-jet');
    if(!jet) return;
    // On scroll down, jet rises
    jet.style.top = (52 - self.progress * 40) + '%';
    jet.style.opacity = 1 - self.progress * .6;
  }
});

// ── CONTATTI FLY-OVER ────────────────────────────────────────────────────────
function flyContJet(){
  const jet = document.getElementById('cont-jet');
  if(!jet) return;
  gsap.fromTo(jet,
    {left:'-280px', opacity:0, rotation:-2},
    {left:'110vw', opacity:[0,.95,.95,0], rotation:2, duration:3.2,
     ease:'power1.inOut', delay:.1}
  );
}

// ── PRENOTA: interior parallax on scroll ──────────────────────────────────────
function initPrenotaScroll(){
  const vis = document.getElementById('prenota-visual');
  const txt = document.getElementById('prenota-scrolltext');
  if(!vis) return;
  const formCol = document.querySelector('.prenota-form-col');
  if(!formCol) return;
  formCol.addEventListener('scroll', ()=>{
    const pct = formCol.scrollTop / (formCol.scrollHeight - formCol.clientHeight);
    if(vis.querySelector('svg')) {
      vis.querySelector('svg').style.transform = `translateY(${-pct * 60}px)`;
    }
    if(txt) txt.style.opacity = 1 - pct * 2;
  }, {passive:true});
}

// ── SCROLL REVEAL ─────────────────────────────────────────────────────────────
const revObs = new IntersectionObserver(entries=>{
  entries.forEach(e=>{ if(e.isIntersecting) e.target.classList.add('vis'); });
},{threshold:.08});
document.querySelectorAll('.fu').forEach(el=>revObs.observe(el));

// ── COUNTDOWNS ───────────────────────────────────────────────────────────────
function startTimer(id,h,m,s){
  let t=h*3600+m*60+s;
  setInterval(()=>{
    t=Math.max(0,t-1);
    const el=document.getElementById(id);
    if(el) el.textContent=[Math.floor(t/3600),Math.floor((t%3600)/60),t%60].map(n=>String(n).padStart(2,'0')).join(':');
  },1000);
}
startTimer('cd1',4,32,18);
startTimer('cd2',11,8,44);
startTimer('cd3',7,55,22);

// ── GSAP parallax on how-steps ───────────────────────────────────────────────
document.querySelectorAll('.how-step').forEach((el,i)=>{
  gsap.from(el,{
    scrollTrigger:{trigger:el,start:'top 88%',toggleActions:'play none none none'},
    y:40, opacity:0, duration:.7, delay:i*.12, ease:'power2.out'
  });
});

// ── NAV scroll shadow ─────────────────────────────────────────────────────────
window.addEventListener('scroll',()=>{
  document.getElementById('mainnav').style.boxShadow = window.scrollY>40 ? '0 2px 20px rgba(10,22,40,.08)' : 'none';
},{passive:true});

// ── INIT ──────────────────────────────────────────────────────────────────────
