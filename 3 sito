html = '''<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Auralis SkyShare — Private Aviation</title>
<!-- 
  ISTRUZIONI GITHUB PAGES:
  1. Carica questo file come index.html nella root del repo
  2. Carica Auralis_Logo.png nella root del repo
  3. Sostituisci l'attributo src del logo con: src="Auralis_Logo.png"
  4. Vai su Settings > Pages > Branch: main > Save
  Il logo è già embedded come base64 per funzionare standalone.
-->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
<style>
:root{
  --navy:#0A1628;
  --navy2:#0E1E38;
  --blue:#4A7BC4;
  --blue2:#6BAED6;
  --gold:#C9A535;
  --gold2:#E8C96A;
  --white:#FFFFFF;
  --off:#F7F9FC;
  --gray:#EEF2F7;
  --text:#0A1628;
  --muted:#607080;
  --bdr:rgba(10,22,40,.1);
  --bdr-g:rgba(201,165,53,.25);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:"Segoe UI",system-ui,-apple-system,sans-serif;background:#fff;color:var(--text);overflow-x:hidden}

/* ─── PAGES ─── */
.page{display:none;animation:pgIn .5s ease}
.page.active{display:block}
@keyframes pgIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

/* ─── NAV ─── */
nav{position:fixed;top:0;left:0;right:0;z-index:9000;background:rgba(255,255,255,.97);backdrop-filter:blur(16px);border-bottom:1px solid var(--bdr);height:66px;display:flex;align-items:center;justify-content:space-between;padding:0 40px;gap:16px}
.nav-logo{cursor:pointer;flex-shrink:0}
.nav-logo img{height:26px;object-fit:contain}
.nav-links{display:flex;gap:4px;list-style:none;flex:1;justify-content:center}
.nav-links a{font-size:12px;letter-spacing:.6px;text-transform:uppercase;color:var(--muted);text-decoration:none;padding:7px 12px;cursor:pointer;transition:color .2s;font-weight:500;border-radius:4px}
.nav-links a:hover,.nav-links a.active-link{color:var(--navy);background:rgba(10,22,40,.04)}
.nav-right{display:flex;gap:10px;flex-shrink:0}
.btn-operator{background:transparent;color:var(--navy);border:1.5px solid var(--navy);padding:9px 20px;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;font-weight:700;cursor:pointer;border-radius:6px;transition:all .25s;white-space:nowrap}
.btn-operator:hover{background:var(--navy);color:#fff}
.btn-reserved{background:var(--navy);color:#fff;border:none;padding:10px 20px;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;font-weight:700;cursor:pointer;border-radius:6px;transition:all .25s;white-space:nowrap}
.btn-reserved:hover{background:var(--gold);color:var(--navy)}

/* ─── OPERATOR MODAL ─── */
.modal-overlay{position:fixed;inset:0;background:rgba(10,22,40,.7);z-index:9500;display:none;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
.modal-overlay.open{display:flex}
.modal-box{background:#fff;max-width:560px;width:90%;padding:52px 48px;position:relative;animation:pgIn .35s ease}
.modal-close{position:absolute;top:16px;right:20px;font-size:22px;cursor:pointer;color:var(--muted);background:none;border:none;line-height:1}
.modal-title{font-size:26px;font-weight:900;color:var(--navy);letter-spacing:-1px;margin-bottom:8px}
.modal-sub{font-size:13px;color:var(--muted);line-height:1.7;margin-bottom:32px}
.modal-options{display:flex;flex-direction:column;gap:12px}
.modal-opt{display:flex;align-items:center;gap:20px;border:1.5px solid var(--bdr);padding:20px 24px;cursor:pointer;transition:all .3s;text-align:left;background:none}
.modal-opt:hover{border-color:var(--gold);background:rgba(201,165,53,.03);transform:translateX(4px)}
.modal-opt-icon{font-size:28px;flex-shrink:0}
.modal-opt-title{font-size:15px;font-weight:800;color:var(--navy);margin-bottom:4px}
.modal-opt-desc{font-size:12px;color:var(--muted);line-height:1.5}
.modal-badge{font-size:9px;letter-spacing:2px;color:var(--gold);border:1px solid var(--bdr-g);padding:3px 10px;margin-left:auto;text-transform:uppercase;white-space:nowrap;flex-shrink:0}

/* ─── AREA RISERVATA MODAL ─── */
.reserved-box{background:#fff;max-width:520px;width:90%;position:relative;animation:pgIn .35s ease;overflow:hidden}
.reserved-header{background:var(--navy);padding:36px 40px;display:flex;align-items:center;gap:16px}
.reserved-header-logo img{height:22px;filter:brightness(0) invert(1)}
.reserved-header-text h2{font-size:18px;font-weight:900;color:#fff;letter-spacing:-.3px}
.reserved-header-text p{font-size:11px;color:rgba(255,255,255,.5);letter-spacing:.5px;margin-top:3px}
.reserved-body{padding:40px}
.reserved-tabs{display:flex;gap:0;border-bottom:1px solid var(--bdr);margin-bottom:28px}
.res-tab{padding:10px 20px;font-size:12px;font-weight:600;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;background:none;border-top:none;border-left:none;border-right:none;letter-spacing:.5px}
.res-tab.active{color:var(--navy);border-bottom-color:var(--gold)}
.res-form{display:flex;flex-direction:column;gap:14px}
.res-input{width:100%;border:1px solid var(--bdr);padding:12px 14px;font-size:13px;color:var(--navy);outline:none;font-family:inherit;transition:border-color .2s;background:#fff}
.res-input:focus{border-color:var(--gold)}
.res-btn{width:100%;padding:14px;background:var(--navy);color:#fff;border:none;font-size:11px;letter-spacing:2px;text-transform:uppercase;font-weight:700;cursor:pointer;transition:all .25s;margin-top:4px}
.res-btn:hover{background:var(--gold);color:var(--navy)}
.res-forgot{font-size:11px;color:var(--muted);text-align:center;margin-top:12px;cursor:pointer;text-decoration:underline}
.res-divider{display:flex;align-items:center;gap:12px;margin:8px 0}
.res-divider span{flex:1;height:1px;background:var(--bdr)}
.res-divider p{font-size:11px;color:var(--muted);white-space:nowrap}
/* Flight history preview */
.flight-history{display:flex;flex-direction:column;gap:10px}
.fh-item{border:1px solid var(--bdr);padding:14px 16px;display:flex;align-items:center;gap:14px;opacity:.5}
.fh-dot{width:8px;height:8px;border-radius:50%;background:var(--gold);flex-shrink:0}
.fh-route{font-size:14px;font-weight:800;color:var(--navy)}
.fh-date{font-size:10px;color:var(--muted);letter-spacing:.5px;margin-top:2px}
.fh-status{margin-left:auto;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;background:rgba(46,158,96,.1);color:#2E9E60;padding:4px 10px;border:1px solid rgba(46,158,96,.2)}

/* ─── HERO ─── */
.hero-wrap{min-height:100vh;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;background:linear-gradient(160deg,#fff 0%,#EEF5FF 45%,#E4EFFA 100%);padding-top:66px}
/* Dawn gradient at bottom */
.hero-dawn{position:absolute;bottom:0;left:0;right:0;height:220px;background:linear-gradient(to top,rgba(255,240,190,.35) 0%,transparent 100%);pointer-events:none}
/* Runway */
.runway-wrap{position:absolute;bottom:0;left:0;right:0;height:38%;pointer-events:none;overflow:hidden}
.hero-content{position:relative;z-index:10;text-align:center;max-width:780px;padding:0 32px}
.hero-badge{display:inline-block;background:rgba(74,123,196,.07);border:1px solid rgba(74,123,196,.18);color:var(--blue);font-size:10px;letter-spacing:2.5px;padding:6px 18px;text-transform:uppercase;font-weight:700;margin-bottom:28px;border-radius:3px}
.hero-eyebrow{font-size:10px;letter-spacing:4px;color:var(--gold);text-transform:uppercase;font-weight:700;margin-bottom:18px;display:flex;align-items:center;justify-content:center;gap:12px}
.hero-eyebrow::before,.hero-eyebrow::after{content:"";width:36px;height:1px;background:var(--gold)}
.hero-h1{font-size:clamp(40px,6vw,76px);font-weight:900;line-height:.95;letter-spacing:-3px;color:var(--navy);margin-bottom:8px}
.hero-h1-gold{font-size:clamp(34px,5vw,62px);font-weight:800;color:var(--gold);letter-spacing:-1.5px;font-style:italic;margin-bottom:28px}
.hero-quote{font-size:16px;color:var(--muted);line-height:1.75;max-width:560px;margin:0 auto 12px;font-style:italic}
.hero-quote strong{color:var(--navy);font-style:normal;font-weight:700}
.hero-sub{font-size:14px;color:var(--muted);line-height:1.75;max-width:500px;margin:0 auto 12px}
.hero-attr{font-size:10px;letter-spacing:2px;color:rgba(10,22,40,.3);text-transform:uppercase;margin-bottom:36px}
.hero-ctas{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.btn-p{background:var(--navy);color:#fff;border:none;padding:15px 34px;font-size:11px;letter-spacing:2px;text-transform:uppercase;font-weight:700;cursor:pointer;border-radius:4px;transition:all .25s}
.btn-p:hover{background:var(--gold);color:var(--navy);transform:translateY(-2px)}
.btn-o{background:transparent;color:var(--navy);border:1.5px solid var(--navy);padding:14px 30px;font-size:11px;letter-spacing:2px;text-transform:uppercase;font-weight:700;cursor:pointer;border-radius:4px;transition:all .25s}
.btn-o:hover{background:var(--navy);color:#fff}

/* ─── STATS ─── */
.stats-bar{background:var(--navy);padding:28px 56px;display:grid;grid-template-columns:repeat(4,1fr)}
.st-i{text-align:center;padding:0 16px;border-right:1px solid rgba(255,255,255,.09)}
.st-i:last-child{border-right:none}
.st-n{font-size:30px;font-weight:900;color:var(--gold2);letter-spacing:-1px}
.st-l{font-size:9px;letter-spacing:2px;color:rgba(255,255,255,.4);text-transform:uppercase;margin-top:5px}

/* ─── COME FUNZIONA (home inline) ─── */
.how-section{padding:96px 56px;background:#fff}
.how-header{text-align:center;margin-bottom:72px}
.sec-eye{font-size:10px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;font-weight:700;display:block;margin-bottom:10px}
.sec-title{font-size:clamp(28px,3.8vw,46px);font-weight:900;letter-spacing:-1.5px;color:var(--navy);line-height:1.05}
.sec-sub{font-size:15px;color:var(--muted);line-height:1.75;max-width:500px;margin:12px auto 0}
.how-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;max-width:1100px;margin:0 auto}
.how-step{background:var(--off);border:1px solid var(--bdr);padding:44px 36px;transition:all .4s;cursor:default;position:relative;overflow:hidden}
.how-step:hover{border-color:var(--bdr-g);background:#fff;transform:translateY(-6px);box-shadow:0 20px 60px rgba(10,22,40,.07)}
.how-step::after{content:"";position:absolute;bottom:0;left:0;right:0;height:3px;background:linear-gradient(to right,var(--gold),var(--gold2));transform:scaleX(0);transition:transform .4s;transform-origin:left}
.how-step:hover::after{transform:scaleX(1)}
.step-n{font-size:52px;font-weight:900;color:rgba(10,22,40,.05);letter-spacing:-2px;margin-bottom:16px;line-height:1}
.step-ico{font-size:26px;margin-bottom:14px}
.step-t{font-size:17px;font-weight:800;color:var(--navy);margin-bottom:10px;letter-spacing:-.3px}
.step-d{font-size:13px;color:var(--muted);line-height:1.75}

/* ─── CHI SIAMO ─── */
.about-hero{min-height:50vh;background:linear-gradient(160deg,var(--navy) 0%,var(--navy2) 60%,#1E3A6E 100%);display:flex;align-items:flex-end;padding-bottom:60px;position:relative;overflow:hidden;margin-top:66px}
.about-hero-content{padding:0 56px;position:relative;z-index:5}
.pg-eye{font-size:10px;letter-spacing:3px;color:var(--gold2);text-transform:uppercase;font-weight:700;display:block;margin-bottom:10px}
.pg-title{font-size:clamp(34px,5.5vw,68px);font-weight:900;letter-spacing:-2.5px;color:#fff;line-height:1}
.about-body{padding:100px 56px;max-width:1100px;margin:0 auto}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center;margin-bottom:80px}
.about-text p{font-size:15px;color:var(--muted);line-height:1.85;margin-bottom:18px}
.about-text p strong{color:var(--navy)}
.about-values{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:100px}
.av-card{background:var(--off);border:1px solid var(--bdr);padding:32px 28px;transition:all .3s}
.av-card:hover{border-color:var(--bdr-g);transform:translateY(-4px)}
.av-n{font-size:9px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;font-weight:700;margin-bottom:10px}
.av-t{font-size:18px;font-weight:800;color:var(--navy);margin-bottom:8px}
.av-d{font-size:13px;color:var(--muted);line-height:1.7}
/* Story numbers */
.story-nums{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:80px}
.sn-i{background:var(--navy);padding:40px 32px;text-align:center}
.sn-n{font-size:38px;font-weight:900;color:var(--gold2);letter-spacing:-1.5px}
.sn-l{font-size:9px;letter-spacing:2px;color:rgba(255,255,255,.4);text-transform:uppercase;margin-top:6px}

/* ─── EMPTY LEG ─── */
.el-hero{min-height:44vh;background:linear-gradient(160deg,var(--navy) 0%,#1A3A6E 100%);display:flex;align-items:flex-end;padding-bottom:52px;position:relative;overflow:hidden;margin-top:66px}
.el-hero-content{padding:0 56px;position:relative;z-index:5}
.el-intro{padding:72px 56px;max-width:1100px;margin:0 auto;text-align:center}
.el-intro-title{font-size:clamp(26px,3.5vw,42px);font-weight:900;letter-spacing:-1.2px;color:var(--navy);margin-bottom:16px}
.el-intro-text{font-size:15px;color:var(--muted);line-height:1.8;max-width:620px;margin:0 auto 40px}
.el-info-strip{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;max-width:1000px;margin:0 auto}
.el-inf{background:var(--off);border:1px solid var(--bdr);padding:28px 24px;text-align:center}
.el-inf-n{font-size:28px;font-weight:900;color:var(--gold);letter-spacing:-1px}
.el-inf-l{font-size:9px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-top:5px}
/* Map */
.map-wrap{background:linear-gradient(135deg,#0A1628 0%,#0E2040 100%);padding:40px 48px;margin:0 56px 0;position:relative;overflow:hidden;min-height:300px}
.map-label{font-size:9px;letter-spacing:2px;color:rgba(255,255,255,.35);text-transform:uppercase;position:absolute;bottom:16px;left:24px;display:flex;align-items:center;gap:8px}
.map-label::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--gold)}
/* Cards */
.el-cards-section{padding:56px 56px 100px;max-width:1100px;margin:0 auto}
.el-cards-title{font-size:18px;font-weight:800;color:var(--navy);letter-spacing:-.5px;margin-bottom:28px;display:flex;align-items:center;gap:12px}
.el-cards-title::after{content:"";flex:1;height:1px;background:var(--bdr)}
.el-cards-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.el-card{background:#fff;border:1px solid var(--bdr);padding:24px;transition:all .3s;cursor:pointer;position:relative;overflow:hidden}
.el-card::before{content:"EMPTY LEG";position:absolute;top:0;right:0;font-size:8px;letter-spacing:1.5px;color:var(--gold);background:rgba(201,165,53,.08);border-left:1px solid var(--bdr-g);border-bottom:1px solid var(--bdr-g);padding:5px 10px;text-transform:uppercase}
.el-card:hover{border-color:var(--bdr-g);box-shadow:0 8px 32px rgba(10,22,40,.07);transform:translateY(-4px)}
.el-rt{display:flex;align-items:center;gap:12px;margin-bottom:18px}
.el-iata{font-size:28px;font-weight:900;color:var(--navy);letter-spacing:-1px}
.el-arr{flex:1;display:flex;align-items:center;gap:6px}
.el-line{flex:1;height:1px;background:linear-gradient(to right,rgba(10,22,40,.15),var(--gold),rgba(10,22,40,.15))}
.el-ico{color:var(--gold);font-size:14px}
.el-meta{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:18px}
.el-m .v{font-size:13px;font-weight:700;color:var(--navy)}
.el-m .k{font-size:9px;letter-spacing:1.5px;color:var(--muted);text-transform:uppercase;margin-top:2px}
.el-foot{display:flex;align-items:flex-end;justify-content:space-between;border-top:1px solid var(--bdr);padding-top:14px;gap:10px}
.el-price{font-size:24px;font-weight:900;color:var(--gold)}
.el-save{font-size:9px;color:#2E9E60;background:rgba(46,158,96,.08);border:1px solid rgba(46,158,96,.2);padding:3px 8px;margin-top:4px;letter-spacing:.5px;display:inline-block}
.el-right{text-align:right;display:flex;flex-direction:column;gap:6px;align-items:flex-end}
.el-cd{font-size:11px;color:var(--muted)}
.el-cd span{color:var(--navy);font-weight:700}
.el-btn{background:var(--navy);color:#fff;border:none;padding:10px 20px;font-size:10px;letter-spacing:2px;text-transform:uppercase;font-weight:700;cursor:pointer;transition:all .25s;border-radius:3px;white-space:nowrap}
.el-btn:hover{background:var(--gold);color:var(--navy)}

/* ─── PRENOTA ORA ─── */
.prenota-wrap{min-height:100vh;margin-top:66px;display:grid;grid-template-columns:55% 45%;position:relative}
/* Left: scroll form */
.prenota-form-col{padding:72px 56px;background:#fff;position:relative;z-index:5;overflow:hidden}
/* Right: 3D jet interior sticky */
.prenota-visual-col{position:sticky;top:66px;height:calc(100vh - 66px);overflow:hidden;background:linear-gradient(160deg,var(--navy) 0%,#0E1E38 100%)}
.prenota-inner-scene{width:100%;height:100%;position:relative}
.p-form-title{font-size:clamp(28px,3vw,40px);font-weight:900;letter-spacing:-1.5px;color:var(--navy);margin-bottom:6px}
.p-form-sub{font-size:13px;color:var(--muted);margin-bottom:36px;line-height:1.7}
.form-sec{margin-bottom:36px}
.form-sec-label{font-size:10px;letter-spacing:2.5px;color:var(--gold);text-transform:uppercase;font-weight:700;margin-bottom:14px;display:flex;align-items:center;gap:10px}
.form-sec-label::before{content:attr(data-n);width:22px;height:22px;border:1px solid var(--bdr-g);display:flex;align-items:center;justify-content:center;font-size:9px;color:var(--gold);border-radius:50%;flex-shrink:0}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.fg{margin-bottom:0;display:flex;flex-direction:column;gap:6px}
.fg label{font-size:9px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;font-weight:600}
.fg input,.fg select,.fg textarea{width:100%;border:1px solid var(--bdr);padding:12px 14px;font-size:13px;color:var(--navy);outline:none;font-family:inherit;transition:border-color .2s;background:#fff;appearance:none}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--gold)}
.submit-big{width:100%;padding:17px;background:var(--navy);color:#fff;border:none;font-size:11px;letter-spacing:3px;text-transform:uppercase;font-weight:700;cursor:pointer;transition:all .3s;margin-top:12px;border-radius:3px}
.submit-big:hover{background:var(--gold);color:var(--navy)}
.submit-note{font-size:10px;color:var(--muted);text-align:center;margin-top:10px}

/* ─── CONTATTI ─── */
.contatti-wrap{min-height:100vh;margin-top:66px;overflow:hidden;position:relative}
.cont-flyover{position:absolute;top:0;left:0;right:0;height:90px;z-index:50;pointer-events:none;overflow:hidden}
.cont-hero{height:52vh;background:linear-gradient(160deg,#060C18 0%,#0E1E38 100%);display:flex;align-items:flex-end;padding:0 56px 52px;position:relative;overflow:hidden}
.cont-body{display:grid;grid-template-columns:1fr 1fr;gap:2px;max-width:1200px;margin:0 auto;padding:0 56px 100px}
.cont-left{padding:60px 0 0 0}
.cont-right{padding:60px 0 0 40px}
.ci{display:flex;align-items:flex-start;gap:16px;padding:20px 0;border-bottom:1px solid var(--bdr)}
.ci:last-child{border-bottom:none}
.ci-icon{width:42px;height:42px;background:rgba(74,123,196,.07);border:1px solid rgba(74,123,196,.14);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.ci-lbl{font-size:9px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:5px;display:block}
.ci-val{font-size:14px;color:var(--navy);font-weight:700}
.ci-sub{font-size:11px;color:var(--muted);margin-top:2px}
.cont-form-title{font-size:22px;font-weight:900;color:var(--navy);letter-spacing:-.5px;margin-bottom:20px}
.cont-form{display:flex;flex-direction:column;gap:12px}
.cont-input{width:100%;border:1px solid var(--bdr);padding:12px 14px;font-size:13px;color:var(--navy);outline:none;font-family:inherit;transition:border-color .2s;background:#fff}
.cont-input:focus{border-color:var(--gold)}
.cont-btn{padding:14px;background:var(--navy);color:#fff;border:none;font-size:10px;letter-spacing:2.5px;text-transform:uppercase;font-weight:700;cursor:pointer;transition:all .25s;border-radius:3px}
