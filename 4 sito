    // Cockpit-style: rings and instrument glow
    for(let r=0;r<5;r++){
      const rad=100+r*80+Math.sin(t*.3+r)*.5;
      ctx.beginPath();ctx.arc(cx,cy*.9,rad,0,Math.PI*2);
      ctx.strokeStyle=`rgba(201,165,53,${.03+r*.01})`;ctx.lineWidth=.5;ctx.stroke();
    }
    // Horizon line
    const hl=ctx.createLinearGradient(cx-w*.35,cy*.9,cx+w*.35,cy*.9);
    hl.addColorStop(0,'rgba(74,123,196,0)');hl.addColorStop(.5,`rgba(74,123,196,${.2+Math.sin(t*.5)*.05})`);hl.addColorStop(1,'rgba(74,123,196,0)');
    ctx.strokeStyle=hl;ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(cx-w*.35,cy*.9);ctx.lineTo(cx+w*.35,cy*.9);ctx.stroke();
    // Vignette
    const vig=ctx.createRadialGradient(cx,cy,0,cx,cy,Math.max(w,h)*.7);
    vig.addColorStop(0,'rgba(0,0,0,0)');vig.addColorStop(1,'rgba(4,10,20,.9)');
    ctx.fillStyle=vig;ctx.fillRect(0,0,w,h);
    const bot=ctx.createLinearGradient(0,h*.6,0,h);
    bot.addColorStop(0,'rgba(4,10,20,0)');bot.addColorStop(1,'rgba(4,10,20,.97)');
    ctx.fillStyle=bot;ctx.fillRect(0,h*.6,w,h*.4);
  }
  draw();
}

