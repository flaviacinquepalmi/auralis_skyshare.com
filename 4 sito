html = r'''<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Auralis SkyShare</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap');

*{margin:0;padding:0;box-sizing:border-box}
:root{
  --cream:#F5F0E8;
  --cream2:#EDE6D8;
  --cream3:#E0D8C8;
  --warm:#D4C4A0;
  --gold:#C9A535;
  --gold2:#E8C96A;
  --navy:#0A1628;
  --navy2:#142140;
  --dark:#060C14;
  --muted:rgba(10,22,40,.45);
  --mutedl:rgba(245,240,232,.5);
}
html,body{width:100%;overflow-x:hidden}
body{background:var(--dark);font-family:'Inter',sans-serif;cursor:none}

/* CURSOR */
#cur{position:fixed;z-index:99999;pointer-events:none}
#cur-d{width:5px;height:5px;background:var(--gold2);border-radius:50%;position:absolute;transform:translate(-50%,-50%);transition:transform .08s}
#cur-r{width:32px;height:32px;border:1px solid rgba(232,201,122,.5);border-radius:50%;position:absolute;transform:translate(-50%,-50%);transition:all .14s ease}

/* LOADER */
#loader{position:fixed;inset:0;z-index:9999;background:var(--dark);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:24px}
#loader-logo{opacity:0;transform:translateY(20px);transition:all 1s ease}
#loader-logo img{height:32px;filter:brightness(0) invert(1) sepia(1) saturate(2) hue-rotate(10deg) brightness(.9)}
.loader-bar{width:200px;height:1px;background:rgba(255,255,255,.1);overflow:hidden;position:relative}
.loader-fill{position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(to right,transparent,var(--gold),transparent);animation:lFill 2.2s ease forwards .3s}
@keyframes lFill{to{left:100%}}
#loader-pct{font-size:11px;letter-spacing:4px;color:rgba(255,255,255,.3);font-family:'Cormorant Garamond',serif}
#loader-sub{font-size:10px;letter-spacing:3px;color:rgba(255,255,255,.2);text-transform:uppercase;font-family:'Inter',sans-serif}

/* NAV */
#nav{position:fixed;top:0;left:0;right:0;z-index:500;padding:28px 48px;display:flex;align-items:center;justify-content:space-between;transition:all .6s ease}
#nav.scrolled{padding:16px 48px;background:rgba(6,12,20,.85);backdrop-filter:blur(20px);border-bottom:1px solid rgba(201,165,53,.08)}
.nav-logo img{height:24px;object-fit:contain;filter:brightness(0) invert(1) sepia(1) saturate(1.5) hue-rotate(10deg) brightness(.85);cursor:pointer;transition:opacity .3s}
.nav-logo img:hover{opacity:.7}
.nav-links{display:flex;gap:36px;list-style:none}
.nav-links a{font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,.45);text-decoration:none;cursor:pointer;transition:color .3s;font-family:'Inter',sans-serif;font-weight:400}
.nav-links a:hover,.nav-links a.act{color:rgba(255,255,255,.9)}
.nav-right{display:flex;gap:12px;align-items:center}
.nav-op{background:transparent;border:1px solid rgba(201,165,53,.4);color:rgba(201,165,53,.85);padding:8px 20px;font-size:10px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;font-family:'Inter',sans-serif;transition:all .3s}
.nav-op:hover{background:var(--gold);color:var(--dark);border-color:var(--gold)}
.nav-ar{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.7);padding:8px 20px;font-size:10px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;font-family:'Inter',sans-serif;transition:all .3s}
.nav-ar:hover{background:rgba(255,255,255,.12);color:#fff}

/* PAGES */
.pg{display:none;animation:pgIn .5s ease}
.pg.act{display:block}
@keyframes pgIn{from{opacity:0}to{opacity:1}}

/* ═══════ HERO / HOME ═══════ */
#pg-home{background:var(--dark)}

/* TUNNEL SCENE */
.tunnel-wrap{position:relative;width:100%;height:100vh;overflow:hidden;perspective:1200px}
.tunnel-canvas{position:absolute;inset:0}

/* CSS 3D tunnel — Cartier-style corridor */
.corridor{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;transform-style:preserve-3d}
.wall-seg{position:absolute;transform-style:preserve-3d}

/* Hero text over tunnel */
.hero-text{position:absolute;inset:0;z-index:20;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:0 40px}
.hero-eyebrow{font-family:'Cormorant Garamond',serif;font-size:13px;letter-spacing:6px;color:rgba(201,165,53,.7);text-transform:uppercase;margin-bottom:28px;opacity:0;transform:translateY(30px);transition:all 1.2s ease}
.hero-eyebrow.show{opacity:1;transform:translateY(0)}
.hero-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(56px,8vw,110px);font-weight:300;line-height:.9;letter-spacing:-2px;color:#fff;margin-bottom:12px;opacity:0;transform:translateY(40px);transition:all 1.2s ease .15s}
.hero-h1.show{opacity:1;transform:translateY(0)}
.hero-h1 em{font-style:italic;color:var(--gold2)}
.hero-h2{font-family:'Cormorant Garamond',serif;font-size:clamp(14px,1.8vw,20px);font-weight:300;color:rgba(255,255,255,.45);letter-spacing:3px;text-transform:uppercase;margin-bottom:40px;opacity:0;transform:translateY(30px);transition:all 1.2s ease .3s}
.hero-h2.show{opacity:1;transform:translateY(0)}
.hero-cta-row{display:flex;gap:16px;justify-content:center;opacity:0;transform:translateY(20px);transition:all 1s ease .5s}
.hero-cta-row.show{opacity:1;transform:translateY(0)}
.cta-main{background:rgba(201,165,53,.12);border:1px solid rgba(201,165,53,.4);color:var(--gold2);padding:14px 40px;font-size:11px;letter-spacing:3px;text-transform:uppercase;cursor:pointer;font-family:'Inter',sans-serif;transition:all .4s;backdrop-filter:blur(10px)}
.cta-main:hover{background:var(--gold);color:var(--dark);letter-spacing:4px}
.cta-sec{background:transparent;border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.6);padding:14px 36px;font-size:11px;letter-spacing:3px;text-transform:uppercase;cursor:pointer;font-family:'Inter',sans-serif;transition:all .4s;backdrop-filter:blur(6px)}
.cta-sec:hover{border-color:rgba(255,255,255,.4);color:#fff}

/* Scroll indicator */
.scroll-ind{position:absolute;bottom:36px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:10px;z-index:30;opacity:0;transition:opacity 1s ease 1.5s}
.scroll-ind.show{opacity:1}
.scroll-line{width:1px;height:56px;background:linear-gradient(to bottom,var(--gold2),transparent);animation:sLine 2s ease-in-out infinite}
@keyframes sLine{0%,100%{opacity:.3;transform:scaleY(1)}50%{opacity:1;transform:scaleY(1.08)}}
.scroll-label{font-size:9px;letter-spacing:3px;color:rgba(255,255,255,.3);text-transform:uppercase;font-family:'Inter',sans-serif}

/* CANVAS 3D scene */
#tunnel-c{position:absolute;inset:0;width:100%;height:100%}

/* SCROLL SECTIONS on home */
.scroll-chapter{height:100vh;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}

/* Chapter 1: Stats */
.ch-stats{background:var(--dark)}
.stats-inner{position:relative;z-index:10;text-align:center}
.stats-eyebrow{font-family:'Cormorant Garamond',serif;font-size:12px;letter-spacing:5px;color:var(--gold);text-transform:uppercase;margin-bottom:40px;display:block}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(255,255,255,.06);max-width:900px;margin:0 auto}
.sg-i{background:var(--dark);padding:48px 32px;text-align:center;position:relative;overflow:hidden;transition:background .4s}
.sg-i:hover{background:rgba(201,165,53,.04)}
.sg-i::after{content:"";position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,var(--gold),transparent);transform:scaleX(0);transition:transform .6s;transform-origin:center}
.sg-i:hover::after{transform:scaleX(1)}
.sg-n{font-family:'Cormorant Garamond',serif;font-size:52px;font-weight:300;color:var(--gold2);letter-spacing:-2px;line-height:1;display:block}
.sg-l{font-size:9px;letter-spacing:2.5px;color:rgba(255,255,255,.3);text-transform:uppercase;margin-top:10px;display:block;font-family:'Inter',sans-serif}

/* Chapter 2: Come Funziona */
.ch-how{background:linear-gradient(180deg,var(--dark) 0%,#0A1020 100%)}
.ch-how-inner{max-width:1000px;margin:0 auto;padding:0 48px;position:relative;z-index:10}
.ch-title{font-family:'Cormorant Garamond',serif;font-size:clamp(36px,5vw,68px);font-weight:300;color:#fff;letter-spacing:-1.5px;line-height:1;margin-bottom:64px;text-align:center}
.ch-title em{font-style:italic;color:var(--gold2)}
.how-line{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,.06)}
.hl-step{background:#0A1020;padding:48px 36px;position:relative;transition:all .5s}
.hl-step:hover{background:rgba(201,165,53,.04)}
.hl-n{font-family:'Cormorant Garamond',serif;font-size:64px;font-weight:300;color:rgba(201,165,53,.08);line-height:1;margin-bottom:20px;letter-spacing:-3px}
.hl-title{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:400;color:#fff;margin-bottom:12px;letter-spacing:-.3px}
.hl-desc{font-size:12px;color:rgba(255,255,255,.38);line-height:1.8;letter-spacing:.3px;font-weight:300}
.hl-line{position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,var(--gold),transparent);transform:scaleX(0);transition:transform .5s;transform-origin:left}
.hl-step:hover .hl-line{transform:scaleX(1)}

/* ANIMATE ON SCROLL */
.anim-up{opacity:0;transform:translateY(50px);transition:opacity .9s ease,transform .9s ease}
.anim-up.vis{opacity:1;transform:translateY(0)}
.anim-up.d1{transition-delay:.12s}
.anim-up.d2{transition-delay:.24s}
.anim-up.d3{transition-delay:.36s}
.anim-fade{opacity:0;transition:opacity 1.2s ease}
.anim-fade.vis{opacity:1}
.anim-split{overflow:hidden}
.anim-split-inner{transform:translateY(100%);transition:transform .9s cubic-bezier(.16,1,.3,1)}
.anim-split.vis .anim-split-inner{transform:translateY(0)}

/* ═══════ EMPTY LEG PAGE ═══════ */
#pg-emptyleg{background:var(--dark);min-height:100vh}
.el-hero-scene{height:100vh;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
#el-canvas{position:absolute;inset:0;width:100%;height:100%}
.el-hero-text{position:relative;z-index:10;text-align:center}
.el-hero-text h1{font-family:'Cormorant Garamond',serif;font-size:clamp(48px,7vw,96px);font-weight:300;color:#fff;letter-spacing:-2px;line-height:.95}
.el-hero-text h1 em{font-style:italic;color:var(--gold2)}
.el-hero-text p{font-size:12px;letter-spacing:3px;color:rgba(255,255,255,.4);text-transform:uppercase;margin-top:20px;font-family:'Inter',sans-serif}

/* Map section */
.el-map-section{padding:0;background:var(--dark);position:relative}
.map-container{background:linear-gradient(135deg,#060C18 0%,#0A1628 100%);margin:0;padding:52px 60px;position:relative;overflow:hidden}
.map-container::before{content:"";position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(201,165,53,.05) 0%,transparent 70%)}
.map-svg{width:100%;display:block}
.map-legend{position:absolute;bottom:20px;left:28px;font-size:9px;letter-spacing:2px;color:rgba(255,255,255,.25);text-transform:uppercase;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:8px}
.map-legend::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--gold);flex-shrink:0}

/* EL cards */
.el-cards-wrap{padding:72px 60px 100px;max-width:1160px;margin:0 auto}
.el-cards-head{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:300;color:#fff;letter-spacing:-1px;margin-bottom:36px;display:flex;align-items:center;gap:20px}
.el-cards-head::after{content:"";flex:1;height:1px;background:rgba(255,255,255,.07)}
.el-cards-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,.07)}
.el-c{background:var(--dark);padding:32px 28px;transition:background .4s;cursor:pointer;position:relative;overflow:hidden}
.el-c:hover{background:#0E1828}
.el-c::before{content:"EMPTY LEG";position:absolute;top:0;right:0;font-size:8px;letter-spacing:1.5px;color:var(--gold);background:rgba(201,165,53,.07);border-left:1px solid rgba(201,165,53,.15);border-bottom:1px solid rgba(201,165,53,.15);padding:5px 12px;font-family:'Inter',sans-serif}
.el-route{display:flex;align-items:center;gap:14px;margin-bottom:24px}
.el-iata{font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:300;color:#fff;letter-spacing:-1px;line-height:1}
.el-arrow-row{flex:1;display:flex;align-items:center;gap:6px}
.el-dash{flex:1;height:1px;background:linear-gradient(to right,rgba(255,255,255,.1),var(--gold),rgba(255,255,255,.1))}
.el-plane{color:var(--gold);font-size:14px}
.el-specs{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:24px}
.el-spec .v{font-size:13px;font-weight:500;color:rgba(255,255,255,.8);font-family:'Inter',sans-serif}
.el-spec .k{font-size:9px;letter-spacing:1.5px;color:rgba(255,255,255,.25);text-transform:uppercase;margin-top:3px;font-family:'Inter',sans-serif}
.el-foot{display:flex;align-items:flex-end;justify-content:space-between;border-top:1px solid rgba(255,255,255,.06);padding-top:18px}
.el-price{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:300;color:var(--gold2);letter-spacing:-1px}
.el-save{font-size:9px;letter-spacing:1px;color:#2E9E60;background:rgba(46,158,96,.08);border:1px solid rgba(46,158,96,.18);padding:3px 8px;margin-top:4px;font-family:'Inter',sans-serif;display:inline-block}
.el-foot-right{text-align:right}
.el-cd{font-size:10px;color:rgba(255,255,255,.28);letter-spacing:.5px;font-family:'Inter',sans-serif;margin-bottom:8px}
.el-cd span{color:rgba(255,255,255,.6);font-weight:500}
.el-btn{background:transparent;border:1px solid rgba(201,165,53,.3);color:var(--gold2);padding:10px 20px;font-size:10px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;font-family:'Inter',sans-serif;transition:all .3s}
.el-btn:hover{background:var(--gold);color:var(--dark);border-color:var(--gold);letter-spacing:2.5px}

/* ═══════ PRENOTA ═══════ */
#pg-prenota{min-height:100vh;background:var(--dark);display:grid;grid-template-columns:1fr 1fr}
.prenota-left{padding:120px 64px 80px;position:relative;overflow:hidden;background:var(--dark)}
#prenota-cabin{position:absolute;inset:0;opacity:.15;pointer-events:none}
.prenota-right{background:linear-gradient(160deg,#060C18 0%,#0A1420 100%);padding:120px 56px 80px;position:sticky;top:0;height:100vh;overflow-y:auto;border-left:1px solid rgba(255,255,255,.05)}
.pren-eyebrow{font-size:10px;letter-spacing:4px;color:var(--gold);text-transform:uppercase;margin-bottom:16px;display:block;font-family:'Inter',sans-serif}
.pren-title{font-family:'Cormorant Garamond',serif;font-size:clamp(32px,4vw,54px);font-weight:300;color:#fff;letter-spacing:-1.5px;line-height:1;margin-bottom:12px}
.pren-sub{font-size:12px;color:rgba(255,255,255,.35);line-height:1.8;margin-bottom:48px;font-family:'Inter',sans-serif;letter-spacing:.3px;max-width:400px}
.f-sec{margin-bottom:36px}
.f-sec-lbl{font-size:9px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;margin-bottom:14px;display:flex;align-items:center;gap:10px;font-family:'Inter',sans-serif}
.f-sec-lbl::before{content:attr(data-n);width:20px;height:20px;border:1px solid rgba(201,165,53,.25);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;color:var(--gold);flex-shrink:0}
.f-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.fg{display:flex;flex-direction:column;gap:6px}
.fg label{font-size:9px;letter-spacing:2px;color:rgba(255,255,255,.25);text-transform:uppercase;font-family:'Inter',sans-serif}
.fg input,.fg select,.fg textarea{width:100%;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);padding:13px 14px;font-size:13px;color:rgba(255,255,255,.8);outline:none;font-family:'Inter',sans-serif;transition:border-color .3s;-webkit-appearance:none}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:rgba(201,165,53,.4)}
.fg input::placeholder,.fg textarea::placeholder{color:rgba(255,255,255,.2)}
.fg select option{background:#0A1628}
.sub-btn{width:100%;padding:16px;background:linear-gradient(135deg,rgba(201,165,53,.15),rgba(201,165,53,.08));border:1px solid rgba(201,165,53,.35);color:var(--gold2);font-size:10px;letter-spacing:3px;text-transform:uppercase;cursor:pointer;font-family:'Inter',sans-serif;transition:all .4s;margin-top:12px}
.sub-btn:hover{background:var(--gold);color:var(--dark);border-color:var(--gold);letter-spacing:3.5px}
.sub-note{font-size:10px;color:rgba(255,255,255,.2);text-align:center;margin-top:12px;letter-spacing:.5px;font-family:'Inter',sans-serif}
/* Right: info panel */
.pr-info-eye{font-size:9px;letter-spacing:3px;color:var(--gold2);text-transform:uppercase;margin-bottom:20px;display:block;font-family:'Inter',sans-serif}
.pr-info-title{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;color:#fff;letter-spacing:-.5px;margin-bottom:28px;line-height:1.1}
.pr-list{list-style:none;margin-bottom:36px}
.pr-list li{font-size:12px;color:rgba(255,255,255,.4);padding:11px 0;border-bottom:1px solid rgba(255,255,255,.05);display:flex;align-items:center;gap:10px;font-family:'Inter',sans-serif;letter-spacing:.3px}
.pr-list li::before{content:"—";color:var(--gold);font-size:10px;flex-shrink:0}
.pr-contact{border:1px solid rgba(255,255,255,.06);padding:24px}
.pr-contact-lbl{font-size:9px;letter-spacing:2.5px;color:var(--gold2);text-transform:uppercase;margin-bottom:14px;display:block;font-family:'Inter',sans-serif}
.pr-contact a{display:block;font-size:12px;color:rgba(255,255,255,.38);text-decoration:none;margin-bottom:8px;letter-spacing:.3px;font-family:'Inter',sans-serif;transition:color .2s}
.pr-contact a:hover{color:rgba(255,255,255,.7)}

/* ═══════ CHI SIAMO ═══════ */
#pg-about{min-height:100vh;background:var(--dark)}
.about-cinematic{height:100vh;position:relative;overflow:hidden;display:flex;align-items:flex-end;padding:0 64px 80px}
#about-canvas{position:absolute;inset:0;width:100%;height:100%}
.about-hero-text{position:relative;z-index:10;max-width:600px}
.abt-eye{font-size:10px;letter-spacing:4px;color:var(--gold2);text-transform:uppercase;margin-bottom:16px;display:block;font-family:'Inter',sans-serif}
.abt-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(44px,6.5vw,80px);font-weight:300;color:#fff;letter-spacing:-2.5px;line-height:.95;margin-bottom:20px}
.abt-h1 em{font-style:italic;color:var(--gold2)}
.abt-p{font-size:13px;color:rgba(255,255,255,.38);line-height:1.8;max-width:480px;font-family:'Inter',sans-serif;letter-spacing:.3px}
.about-body{padding:100px 64px;max-width:1100px;margin:0 auto}
.abt-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start;margin-bottom:100px}
.abt-text-block p{font-size:13px;color:rgba(255,255,255,.38);line-height:1.9;margin-bottom:18px;font-family:'Inter',sans-serif;letter-spacing:.3px}
.abt-text-block p strong{color:rgba(255,255,255,.75);font-weight:500}
.abt-nums{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,.06);margin-bottom:80px}
.abn-i{background:var(--dark);padding:48px 32px;text-align:center}
.abn-n{font-family:'Cormorant Garamond',serif;font-size:48px;font-weight:300;color:var(--gold2);letter-spacing:-2px;display:block;line-height:1}
.abn-l{font-size:9px;letter-spacing:2.5px;color:rgba(255,255,255,.25);text-transform:uppercase;margin-top:8px;display:block;font-family:'Inter',sans-serif}
.abt-values{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:rgba(255,255,255,.06)}
.av{background:var(--dark);padding:40px 36px;transition:background .4s;position:relative;overflow:hidden}
.av:hover{background:#0E1828}
.av-n{font-size:9px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;margin-bottom:12px;font-family:'Inter',sans-serif}
.av-t{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:300;color:#fff;margin-bottom:10px;letter-spacing:-.3px}
.av-d{font-size:12px;color:rgba(255,255,255,.32);line-height:1.8;font-family:'Inter',sans-serif;letter-spacing:.3px}
.av-line{position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,var(--gold),transparent);transform:scaleX(0);transition:transform .5s;transform-origin:left}
.av:hover .av-line{transform:scaleX(1)}

/* ═══════ CONTATTI ═══════ */
#pg-contatti{min-height:100vh;background:var(--dark)}
.cont-scene{height:100vh;position:relative;overflow:hidden;display:flex;align-items:flex-end;padding:0 64px 80px}
#cont-canvas{position:absolute;inset:0;width:100%;height:100%}
.cont-fly-jet{position:absolute;top:0;left:0;right:0;height:120px;z-index:50;overflow:hidden;pointer-events:none}
#fly-jet-svg{position:absolute;top:28px;left:-280px}
.cont-hero-text{position:relative;z-index:10}
.cont-body{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(255,255,255,.06)}
.cont-left{background:var(--dark);padding:72px 64px}
.cont-right{background:#070D1A;padding:72px 56px}
.cont-title{font-family:'Cormorant Garamond',serif;font-size:clamp(28px,3.5vw,42px);font-weight:300;color:#fff;letter-spacing:-1.2px;margin-bottom:40px;line-height:1}
.cont-title em{font-style:italic;color:var(--gold2)}
.ci-item{display:flex;align-items:flex-start;gap:18px;padding:20px 0;border-bottom:1px solid rgba(255,255,255,.05)}
.ci-ico{width:38px;height:38px;border:1px solid rgba(201,165,53,.15);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;color:var(--gold)}
.ci-lbl{font-size:9px;letter-spacing:2px;color:rgba(255,255,255,.25);text-transform:uppercase;margin-bottom:5px;display:block;font-family:'Inter',sans-serif}
.ci-val{font-size:13px;color:rgba(255,255,255,.7);font-family:'Inter',sans-serif;font-weight:400}
.ci-sub{font-size:11px;color:rgba(255,255,255,.25);margin-top:3px;font-family:'Inter',sans-serif}
.cont-form{display:flex;flex-direction:column;gap:12px}
.cont-form-title{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:300;color:#fff;letter-spacing:-.5px;margin-bottom:24px}
.c-input{width:100%;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);padding:13px 14px;font-size:13px;color:rgba(255,255,255,.7);outline:none;font-family:'Inter',sans-serif;transition:border-color .3s}
.c-input:focus{border-color:rgba(201,165,53,.35)}
.c-input::placeholder{color:rgba(255,255,255,.18)}
.c-btn{padding:14px;background:rgba(201,165,53,.1);border:1px solid rgba(201,165,53,.3);color:var(--gold2);font-size:10px;letter-spacing:2.5px;text-transform:uppercase;cursor:pointer;font-family:'Inter',sans-serif;transition:all .3s}
.c-btn:hover{background:var(--gold);color:var(--dark);border-color:var(--gold)}

/* PARTNER / PILOT pages */
#pg-partner,#pg-pilot{min-height:100vh;background:var(--dark)}
.op-hero{height:100vh;position:relative;overflow:hidden;display:flex;align-items:flex-end;padding:0 64px 80px}
#part-canvas,#pilot-canvas{position:absolute;inset:0;width:100%;height:100%}
.op-reserved-badge{display:inline-block;background:rgba(201,165,53,.1);border:1px solid rgba(201,165,53,.25);color:rgba(201,165,53,.8);font-size:9px;letter-spacing:2.5px;padding:6px 16px;text-transform:uppercase;margin-bottom:16px;font-family:'Inter',sans-serif}
.op-title{font-family:'Cormorant Garamond',serif;font-size:clamp(44px,7vw,88px);font-weight:300;color:#fff;letter-spacing:-3px;line-height:.9;margin-bottom:16px}
.op-title em{font-style:italic;color:var(--gold2)}
.op-sub{font-size:12px;color:rgba(255,255,255,.35);letter-spacing:.5px;font-family:'Inter',sans-serif;max-width:420px;line-height:1.7}
.op-body{padding:80px 64px;max-width:1100px;margin:0 auto}
.op-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(255,255,255,.06);margin-bottom:2px}
.op-card{background:var(--dark);padding:44px 36px;transition:background .4s;position:relative;overflow:hidden}
.op-card:hover{background:#0C1624}
.op-card-n{font-size:9px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;margin-bottom:12px;font-family:'Inter',sans-serif}
.op-card-t{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:300;color:#fff;margin-bottom:12px;letter-spacing:-.3px}
.op-card-d{font-size:12px;color:rgba(255,255,255,.3);line-height:1.8;font-family:'Inter',sans-serif;letter-spacing:.3px}
.op-tags{display:flex;flex-wrap:wrap;gap:6px;margin-top:16px}
.op-tag{font-size:9px;color:rgba(201,165,53,.7);background:rgba(201,165,53,.06);border:1px solid rgba(201,165,53,.15);padding:4px 12px;font-family:'Inter',sans-serif;letter-spacing:.5px}
.op-card-line{position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,var(--gold),transparent);transform:scaleX(0);transition:transform .5s;transform-origin:left}
.op-card:hover .op-card-line{transform:scaleX(1)}
.op-cta-band{background:linear-gradient(135deg,rgba(201,165,53,.06) 0%,rgba(201,165,53,.02) 100%);border:1px solid rgba(201,165,53,.1);padding:64px;display:grid;grid-template-columns:1fr auto;gap:40px;align-items:center}
.op-cta-t{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:300;color:#fff;letter-spacing:-1px;line-height:1.1}
.op-cta-s{font-size:12px;color:rgba(255,255,255,.3);margin-top:10px;line-height:1.7;font-family:'Inter',sans-serif;letter-spacing:.3px}
.op-pill-row{display:flex;flex-wrap:wrap;gap:8px;margin-top:16px}
.op-pill{font-size:10px;color:var(--gold2);background:rgba(201,165,53,.08);border:1px solid rgba(201,165,53,.2);padding:5px 14px;font-family:'Inter',sans-serif;letter-spacing:.5px}
.op-btn{background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--dark);border:none;padding:16px 40px;font-size:10px;letter-spacing:2.5px;text-transform:uppercase;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;transition:all .3s;flex-shrink:0}
.op-btn:hover{opacity:.85;transform:translateY(-2px)}

/* MODALS */
.modal-bg{position:fixed;inset:0;z-index:8000;background:rgba(6,12,20,.9);backdrop-filter:blur(12px);display:none;align-items:center;justify-content:center}
.modal-bg.open{display:flex}
.modal-box{background:#0A1220;border:1px solid rgba(255,255,255,.08);max-width:520px;width:90%;position:relative;animation:pgIn .3s ease}
.modal-box::before{content:"";position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,var(--gold),transparent)}
.modal-hd{padding:40px 44px 0}
.modal-close{position:absolute;top:16px;right:20px;background:none;border:none;color:rgba(255,255,255,.3);font-size:22px;cursor:pointer;line-height:1;transition:color .2s}
.modal-close:hover{color:rgba(255,255,255,.7)}
.modal-title{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;color:#fff;letter-spacing:-.5px;margin-bottom:8px}
.modal-sub{font-size:12px;color:rgba(255,255,255,.3);line-height:1.7;font-family:'Inter',sans-serif;letter-spacing:.3px}
.modal-body{padding:28px 44px 40px}
.modal-opts{display:flex;flex-direction:column;gap:10px}
.modal-opt{background:transparent;border:1px solid rgba(255,255,255,.07);padding:20px 22px;cursor:pointer;display:flex;align-items:center;gap:18px;text-align:left;transition:all .3s;font-family:'Inter',sans-serif}
.modal-opt:hover{border-color:rgba(201,165,53,.3);background:rgba(201,165,53,.04)}
.modal-opt-ico{font-size:24px;flex-shrink:0}
.modal-opt-title{font-size:14px;font-weight:500;color:rgba(255,255,255,.8);margin-bottom:4px}
.modal-opt-desc{font-size:11px;color:rgba(255,255,255,.3);line-height:1.5;letter-spacing:.2px}
.modal-badge{margin-left:auto;font-size:8px;letter-spacing:2px;color:var(--gold);border:1px solid rgba(201,165,53,.2);padding:4px 10px;flex-shrink:0;text-transform:uppercase}

/* Area Riservata modal */
.ar-hd{background:linear-gradient(135deg,#0A1628 0%,#0E2040 100%);padding:32px 40px;display:flex;align-items:center;gap:14px;border-bottom:1px solid rgba(255,255,255,.06)}
.ar-hd img{height:20px;filter:brightness(0) invert(1) sepia(1) saturate(1.5) hue-rotate(10deg) brightness(.85)}
.ar-hd-t h2{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:300;color:#fff;letter-spacing:-.3px}
.ar-hd-t p{font-size:10px;color:rgba(255,255,255,.3);letter-spacing:1px;margin-top:2px;font-family:'Inter',sans-serif}
.ar-body{padding:32px 40px 40px}
.ar-tabs{display:flex;gap:0;border-bottom:1px solid rgba(255,255,255,.07);margin-bottom:24px}
.ar-tab{padding:9px 20px;font-size:11px;font-weight:400;color:rgba(255,255,255,.3);cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;background:none;border-top:none;border-left:none;border-right:none;letter-spacing:1px;font-family:'Inter',sans-serif}
.ar-tab.act{color:#fff;border-bottom-color:var(--gold)}
.ar-form{display:flex;flex-direction:column;gap:12px}
.ar-input{width:100%;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);padding:12px 14px;font-size:13px;color:rgba(255,255,255,.8);outline:none;font-family:'Inter',sans-serif;transition:border-color .2s}
.ar-input:focus{border-color:rgba(201,165,53,.3)}
.ar-input::placeholder{color:rgba(255,255,255,.2)}
.ar-btn{width:100%;padding:13px;background:rgba(201,165,53,.1);border:1px solid rgba(201,165,53,.3);color:var(--gold2);font-size:10px;letter-spacing:2.5px;text-transform:uppercase;cursor:pointer;font-family:'Inter',sans-serif;transition:all .3s;margin-top:4px}
.ar-btn:hover{background:var(--gold);color:var(--dark);border-color:var(--gold)}
.ar-divider{display:flex;align-items:center;gap:12px;margin:8px 0}
.ar-divider span{flex:1;height:1px;background:rgba(255,255,255,.07)}
.ar-divider p{font-size:10px;color:rgba(255,255,255,.2);font-family:'Inter',sans-serif;white-space:nowrap}
.ar-forgot{font-size:10px;color:rgba(255,255,255,.25);text-align:center;margin-top:10px;cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:.5px}
/* History */
.ar-fh{display:flex;flex-direction:column;gap:8px}
.ar-fh-i{border:1px solid rgba(255,255,255,.06);padding:14px 16px;display:flex;align-items:center;gap:12px;transition:background .3s}
.ar-fh-i:hover{background:rgba(255,255,255,.03)}
.ar-fh-dot{width:6px;height:6px;border-radius:50%;background:var(--gold);flex-shrink:0}
.ar-fh-route{font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:300;color:#fff;letter-spacing:-.3px}
.ar-fh-date{font-size:9px;color:rgba(255,255,255,.25);letter-spacing:1px;margin-top:2px;font-family:'Inter',sans-serif;text-transform:uppercase}
.ar-fh-status{margin-left:auto;font-size:8px;letter-spacing:1.5px;text-transform:uppercase;padding:4px 10px;font-family:'Inter',sans-serif}
.ar-fh-status.done{background:rgba(46,158,96,.08);color:#2E9E60;border:1px solid rgba(46,158,96,.18)}
.ar-fh-status.bkd{background:rgba(74,123,196,.08);color:#6BAED6;border:1px solid rgba(74,123,196,.18)}

/* FOOTER */
footer{background:#040A12;padding:64px;border-top:1px solid rgba(255,255,255,.04)}
.ft{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;margin-bottom:48px}
.ft-logo img{height:20px;filter:brightness(0) invert(1) sepia(1) saturate(1.5) hue-rotate(10deg) brightness(.85);margin-bottom:16px}
.ft-desc{font-size:11px;color:rgba(255,255,255,.2);line-height:1.8;max-width:220px;font-family:'Inter',sans-serif;letter-spacing:.3px}
.ft-tag{font-size:9px;letter-spacing:2.5px;color:rgba(201,165,53,.5);text-transform:uppercase;margin-top:14px;display:block;font-family:'Inter',sans-serif}
.ft-col h4{font-size:9px;letter-spacing:3px;color:rgba(255,255,255,.2);text-transform:uppercase;margin-bottom:16px;font-weight:400;font-family:'Inter',sans-serif}
.ft-col a{display:block;font-size:11px;color:rgba(255,255,255,.2);text-decoration:none;margin-bottom:9px;cursor:pointer;transition:color .2s;font-family:'Inter',sans-serif;letter-spacing:.3px}
.ft-col a:hover{color:rgba(255,255,255,.55)}
.ft-bot{border-top:1px solid rgba(255,255,255,.04);padding-top:24px;display:flex;justify-content:space-between;font-size:10px;color:rgba(255,255,255,.15);font-family:'Inter',sans-serif;letter-spacing:.3px}

/* UTIL */
.rel{position:relative}
</style>
</head>
