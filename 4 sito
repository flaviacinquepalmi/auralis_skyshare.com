// ── CANVAS: TUNNEL (Home hero — Cartier-style hangar corridor) ────────────────
function drawTunnel(){
  const c=document.getElementById('tunnel-c');if(!c)return;
  const ctx=c.getContext('2d');
  c.width=window.innerWidth;c.height=window.innerHeight;
  let t=0,scrollPct=0;

  // Camera Z driven by scroll
  window.addEventListener('scroll',()=>{
    if(currentPage!=='home')return;
    scrollPct=window.scrollY/(document.getElementById('pg-home').scrollHeight-window.innerHeight||1);
  },{passive:true});

  function drawFrame(){
    if(currentPage!=='home'){return;}
    requestAnimationFrame(drawFrame);
    t+=.008;
    const w=c.width,h=c.height,cx=w/2,cy=h/2;

    // Deep dark background
    ctx.fillStyle='#060C14';ctx.fillRect(0,0,w,h);

    // Subtle vignette gradient
    const vig=ctx.createRadialGradient(cx,cy,0,cx,cy,Math.max(w,h)*.7);
    vig.addColorStop(0,'rgba(0,0,0,0)');vig.addColorStop(1,'rgba(0,0,0,.75)');
    ctx.fillStyle=vig;ctx.fillRect(0,0,w,h);

    // Camera zoom from scroll (Cartier-style forward motion)
    const camZ=scrollPct*3;
    const fov=1.2+camZ*.3;

    // Draw corridor segments (vanishing point perspective)
    const vx=cx,vy=cy*.95;
    const numSegs=14;
    const baseW=w*.9,baseH=h*.9;

    for(let i=numSegs;i>=0;i--){
      const prog=(i-camZ*2)/(numSegs);
      if(prog<0||prog>1)continue;
      const ease=Math.pow(prog,1.4);
      const sw=baseW*ease,sh=baseH*ease;
      const sx=vx-sw/2,sy=vy-sh/2;

      // Warm gold tint deepens toward viewer
      const glowAmt=1-ease;
      const warmR=Math.floor(20+glowAmt*40);
      const warmG=Math.floor(12+glowAmt*24);
      const warmB=Math.floor(6+glowAmt*8);
      const alpha=(.05+ease*.25)*(1-Math.abs(Math.sin(t*.5+i*.3))*.1);

      // Floor plane
      const floorY=vy+sh*.5;
      const floorFarY=vy+sh*.5*ease*.3;
      const floorFarX1=vx-sw*.5*ease*.3,floorFarX2=vx+sw*.5*ease*.3;
      const floorX1=sx,floorX2=sx+sw;
      if(i>0){
        ctx.beginPath();
        ctx.moveTo(floorX1,floorY);ctx.lineTo(floorX2,floorY);
        ctx.lineTo(floorFarX2,floorFarY);ctx.lineTo(floorFarX1,floorFarY);
        ctx.closePath();
        const fg=ctx.createLinearGradient(0,floorFarY,0,floorY);
        fg.addColorStop(0,`rgba(${warmR},${warmG},${warmB},${alpha*.4})`);
        fg.addColorStop(1,`rgba(${warmR+10},${warmG+8},${warmB+4},${alpha*.15})`);
        ctx.fillStyle=fg;ctx.fill();
      }

      // Ceiling plane
      const ceilY=vy-sh*.5;
      const ceilFarY=vy-sh*.5*ease*.3;
      if(i>0){
        ctx.beginPath();
        ctx.moveTo(floorX1,ceilY);ctx.lineTo(floorX2,ceilY);
        ctx.lineTo(floorFarX2,ceilFarY);ctx.lineTo(floorFarX1,ceilFarY);
        ctx.closePath();
        const cg=ctx.createLinearGradient(0,ceilFarY,0,ceilY);
        cg.addColorStop(0,`rgba(${warmR},${warmG},${warmB},${alpha*.3})`);
        cg.addColorStop(1,`rgba(${warmR},${warmG},${warmB},${alpha*.08})`);
        ctx.fillStyle=cg;ctx.fill();
      }

      // Left wall
      const lx=sx;
      if(i>0){
        ctx.beginPath();
        ctx.moveTo(lx,ceilY);ctx.lineTo(lx,floorY);
        ctx.lineTo(floorFarX1,floorFarY);ctx.lineTo(floorFarX1,ceilFarY);
        ctx.closePath();
        const lg=ctx.createLinearGradient(floorFarX1,0,lx,0);
        lg.addColorStop(0,`rgba(${warmR},${warmG},${warmB},${alpha*.5})`);
        lg.addColorStop(1,`rgba(${warmR+5},${warmG+4},${warmB},${alpha*.1})`);
        ctx.fillStyle=lg;ctx.fill();
      }

      // Right wall
      const rx2=sx+sw;
      if(i>0){
        ctx.beginPath();
        ctx.moveTo(rx2,ceilY);ctx.lineTo(rx2,floorY);
        ctx.lineTo(floorFarX2,floorFarY);ctx.lineTo(floorFarX2,ceilFarY);
        ctx.closePath();
        const rg=ctx.createLinearGradient(rx2,0,floorFarX2,0);
        rg.addColorStop(0,`rgba(${warmR},${warmG},${warmB},${alpha*.1})`);
        rg.addColorStop(1,`rgba(${warmR},${warmG},${warmB},${alpha*.5})`);
        ctx.fillStyle=rg;ctx.fill();
      }

      // Corridor frame / edge lines
      ctx.strokeStyle=`rgba(201,165,53,${alpha*.6})`;ctx.lineWidth=.5;
      ctx.strokeRect(sx,sy,sw,sh);

      // Gold ceiling light strip (Cartier-style warm ambient)
      if(i<numSegs-1&&ease>.15){
        const lightW=sw*.08,lightH=sh*.005;
        const lx2=vx-lightW/2,ly2=sy+sh*.02;
        const lg2=ctx.createLinearGradient(lx2,0,lx2+lightW,0);
        lg2.addColorStop(0,'rgba(201,165,53,0)');
        lg2.addColorStop(.5,`rgba(232,201,122,${alpha*1.2})`);
        lg2.addColorStop(1,'rgba(201,165,53,0)');
        ctx.fillStyle=lg2;
        ctx.fillRect(lx2,ly2,lightW,lightH);
      }
    }

    // Central vanishing point glow (the "end of corridor" light)
    const vpGlow=ctx.createRadialGradient(vx,vy,0,vx,vy,w*.25);
    vpGlow.addColorStop(0,`rgba(201,165,53,${.08+Math.sin(t*.7)*.02})`);
    vpGlow.addColorStop(.5,'rgba(180,140,80,.03)');
    vpGlow.addColorStop(1,'rgba(0,0,0,0)');
    ctx.fillStyle=vpGlow;ctx.fillRect(0,0,w,h);

    // Floor reflection line
    const reflGrad=ctx.createLinearGradient(cx-w*.3,cy+h*.45,cx+w*.3,cy+h*.45);
    reflGrad.addColorStop(0,'rgba(201,165,53,0)');
    reflGrad.addColorStop(.5,`rgba(201,165,53,${.15+Math.sin(t)*.03})`);
    reflGrad.addColorStop(1,'rgba(201,165,53,0)');
    ctx.strokeStyle=reflGrad;ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(cx-w*.3,cy+h*.45);ctx.lineTo(cx+w*.3,cy+h*.45);ctx.stroke();

    // Moving particles (dust in corridor)
    for(let p=0;p<20;p++){
      const px=cx+Math.sin(t*.5+p*1.7)*w*.1;
      const py=cy+Math.cos(t*.4+p*2.1)*h*.15;
      const ps=.5+Math.sin(t+p)*.3;
      ctx.beginPath();ctx.arc(px,py,ps,0,Math.PI*2);
      ctx.fillStyle=`rgba(232,201,122,${.1+Math.sin(t*1.2+p)*.06})`;ctx.fill();
    }

    // Top vignette
    const topV=ctx.createLinearGradient(0,0,0,h*.15);
    topV.addColorStop(0,'rgba(6,12,20,.8)');topV.addColorStop(1,'rgba(6,12,20,0)');
    ctx.fillStyle=topV;ctx.fillRect(0,0,w,h*.15);

    // Bottom vignette
    const botV=ctx.createLinearGradient(0,h*.75,0,h);
    botV.addColorStop(0,'rgba(6,12,20,0)');botV.addColorStop(1,'rgba(6,12,20,.9)');
    ctx.fillStyle=botV;ctx.fillRect(0,h*.75,w,h*.25);
  }
  drawFrame();
}

// ── CANVAS: EMPTY LEG hero ───────────────────────────────────────────────────
function drawElScene(){
  const c=document.getElementById('el-canvas');if(!c)return;
  c.width=window.innerWidth;c.height=window.innerHeight;
  const ctx=c.getContext('2d');let t=0;
  function draw(){
    if(currentPage!=='emptyleg')return;
    requestAnimationFrame(draw);t+=.006;
    const w=c.width,h=c.height,cx=w/2,cy=h/2;
    ctx.fillStyle='#040A14';ctx.fillRect(0,0,w,h);
    // Star field
    for(let i=0;i<200;i++){
      const sx=((Math.sin(i*2.7+t*.02)*500+cx+i*6.3)%w+w)%w;
      const sy=((Math.cos(i*1.9+t*.015)*400+cy+i*4.1)%h+h)%h;
      const sa=.2+Math.sin(t*2+i)*.15;
      ctx.beginPath();ctx.arc(sx,sy,.8+Math.sin(i)*.4,0,Math.PI*2);
      ctx.fillStyle=`rgba(232,201,122,${sa})`;ctx.fill();
    }
    // Horizon glow
    const hg=ctx.createLinearGradient(0,h*.55,0,h);
    hg.addColorStop(0,'rgba(201,165,53,.04)');hg.addColorStop(1,'rgba(10,22,40,.95)');
    ctx.fillStyle=hg;ctx.fillRect(0,h*.55,w,h*.45);
    // Animated jet silhouette flying across
    const jx=((t*180)%(w+300))-150;
    const jy=h*.32+Math.sin(t*.5)*30;
    ctx.save();ctx.translate(jx,jy);ctx.scale(1.4,1.4);
    ctx.fillStyle='rgba(232,201,122,.7)';
    ctx.beginPath();ctx.ellipse(0,0,60,7,0,0,Math.PI*2);ctx.fill();
    // Wings
    ctx.beginPath();ctx.moveTo(10,0);ctx.lineTo(32,-16);ctx.lineTo(38,-14);ctx.lineTo(20,0);ctx.closePath();ctx.fillStyle='rgba(201,165,53,.65)';ctx.fill();
    ctx.beginPath();ctx.moveTo(10,0);ctx.lineTo(32,16);ctx.lineTo(38,14);ctx.lineTo(20,0);ctx.closePath();ctx.fillStyle='rgba(160,128,32,.65)';ctx.fill();
    // Contrail
    const cg=ctx.createLinearGradient(-80,0,0,0);
    cg.addColorStop(0,'rgba(255,255,255,0)');cg.addColorStop(1,'rgba(255,255,255,.3)');
    ctx.strokeStyle=cg;ctx.lineWidth=1.5;
    ctx.beginPath();ctx.moveTo(-80,0);ctx.lineTo(-2,0);ctx.stroke();
    ctx.restore();
    // Vignette
    const vig=ctx.createRadialGradient(cx,cy,0,cx,cy,Math.max(w,h)*.7);
    vig.addColorStop(0,'rgba(0,0,0,0)');vig.addColorStop(1,'rgba(4,10,20,.85)');
    ctx.fillStyle=vig;ctx.fillRect(0,0,w,h);
    const top=ctx.createLinearGradient(0,0,0,h*.2);
    top.addColorStop(0,'rgba(4,10,20,.7)');top.addColorStop(1,'rgba(4,10,20,0)');
    ctx.fillStyle=top;ctx.fillRect(0,0,w,h*.2);
    const bot=ctx.createLinearGradient(0,h*.7,0,h);
    bot.addColorStop(0,'rgba(4,10,20,0)');bot.addColorStop(1,'rgba(4,10,20,.95)');
    ctx.fillStyle=bot;ctx.fillRect(0,h*.7,w,h*.3);
  }
  draw();
}

// ── CANVAS: About (Hangar corridor) ──────────────────────────────────────────
function drawAboutScene(){
  const c=document.getElementById('about-canvas');if(!c)return;
  c.width=window.innerWidth;c.height=window.innerHeight;
  const ctx=c.getContext('2d');let t=0;
  function draw(){
    if(currentPage!=='about')return;
    requestAnimationFrame(draw);t+=.005;
    const w=c.width,h=c.height,cx=w/2,cy=h/2;
    ctx.fillStyle='#040A14';ctx.fillRect(0,0,w,h);
    // Simple hangar corridor — lighter than home, with warm amber
    const vx=cx,vy=cy;
    for(let i=8;i>=0;i--){
      const ease=Math.pow(i/8,1.3);
      const sw=w*.85*ease,sh=h*.85*ease;
      const sx=vx-sw/2,sy=vy-sh/2;
      const alpha=(.08+ease*.18)*(1-Math.sin(t*.3+i*.5)*.05);
      ctx.strokeStyle=`rgba(201,165,53,${alpha})`;ctx.lineWidth=.6;
      ctx.strokeRect(sx,sy,sw,sh);
      // Warm glow on ceiling
      if(ease>.2){
        const cLght=ctx.createLinearGradient(sx+sw*.35,sy,sx+sw*.65,sy);
        cLght.addColorStop(0,'rgba(201,165,53,0)');
        cLght.addColorStop(.5,`rgba(232,201,122,${alpha*1.5})`);
        cLght.addColorStop(1,'rgba(201,165,53,0)');
        ctx.fillStyle=cLght;ctx.fillRect(sx+sw*.35,sy,sw*.3,2);
      }
    }
    // Floor reflection
    const fl=ctx.createLinearGradient(cx-w*.4,cy+h*.4,cx+w*.4,cy+h*.4);
    fl.addColorStop(0,'rgba(201,165,53,0)');fl.addColorStop(.5,`rgba(201,165,53,${.12+Math.sin(t)*.03})`);fl.addColorStop(1,'rgba(201,165,53,0)');
    ctx.strokeStyle=fl;ctx.lineWidth=.8;
    ctx.beginPath();ctx.moveTo(cx-w*.4,cy+h*.4);ctx.lineTo(cx+w*.4,cy+h*.4);ctx.stroke();
    // Vignette
    const vig=ctx.createRadialGradient(cx,cy,0,cx,cy,Math.max(w,h)*.7);
    vig.addColorStop(0,'rgba(0,0,0,0)');vig.addColorStop(1,'rgba(4,10,20,.9)');
    ctx.fillStyle=vig;ctx.fillRect(0,0,w,h);
    const bot=ctx.createLinearGradient(0,h*.6,0,h);
    bot.addColorStop(0,'rgba(4,10,20,0)');bot.addColorStop(1,'rgba(4,10,20,.97)');
    ctx.fillStyle=bot;ctx.fillRect(0,h*.6,w,h*.4);
  }
  draw();
}

// ── CANVAS: Contatti (Runway at dusk) ────────────────────────────────────────
function drawContScene(){
  const c=document.getElementById('cont-canvas');if(!c)return;
  c.width=window.innerWidth;c.height=window.innerHeight;
  const ctx=c.getContext('2d');let t=0;
  function draw(){
    if(currentPage!=='contatti')return;
    requestAnimationFrame(draw);t+=.006;
    const w=c.width,h=c.height,cx=w/2;
    // Night sky gradient
    const sky=ctx.createLinearGradient(0,0,0,h*.65);
    sky.addColorStop(0,'#020610');sky.addColorStop(.7,'#060C1A');sky.addColorStop(1,'rgba(20,30,50,.8)');
    ctx.fillStyle=sky;ctx.fillRect(0,0,w,h);
    // Stars
    for(let i=0;i<150;i++){
      const sx=((i*137+50)%w),sy=((i*97+30)%(h*.55));
      const sa=.1+Math.sin(t*1.5+i)*.12;
      ctx.beginPath();ctx.arc(sx,sy,.5+Math.sin(i)*.3,0,Math.PI*2);
      ctx.fillStyle=`rgba(255,255,240,${sa})`;ctx.fill();
    }
    // Horizon glow (city / dawn)
    const hg=ctx.createRadialGradient(cx,h*.62,0,cx,h*.62,w*.5);
    hg.addColorStop(0,'rgba(201,165,53,.08)');hg.addColorStop(1,'rgba(0,0,0,0)');
    ctx.fillStyle=hg;ctx.fillRect(0,h*.4,w,h*.3);
    // Ground
    ctx.fillStyle='#060C14';ctx.fillRect(0,h*.65,w,h*.35);
    // Runway perspective
    const rwL=cx-w*.07,rwR=cx+w*.07;
    const rwFarL=cx-8,rwFarR=cx+8;
    const rwTop=h*.63,rwBot=h;
    ctx.beginPath();ctx.moveTo(rwL,rwBot);ctx.lineTo(rwFarL,rwTop);ctx.lineTo(rwFarR,rwTop);ctx.lineTo(rwR,rwBot);ctx.closePath();
    ctx.fillStyle='rgba(20,32,52,.6)';ctx.fill();
    // Runway edge lights
    for(let li=0;li<12;li++){
      const lp=li/11,lx=rwL+(rwFarL-rwL)*Math.pow(lp,1.5),ly=rwBot+(rwTop-rwBot)*Math.pow(lp,1.5);
      const la=.2+Math.sin(t*3+li*.5)*.15;
      ctx.beginPath();ctx.arc(lx,ly,2.5+la*1.5,0,Math.PI*2);
      ctx.fillStyle=`rgba(255,255,200,${.5+la})`;ctx.fill();
      const rg=ctx.createRadialGradient(lx,ly,0,lx,ly,12);
      rg.addColorStop(0,`rgba(255,255,200,${la*.4})`);rg.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=rg;ctx.fillRect(lx-12,ly-12,24,24);
      // Right side
      const rlx=rwR+(rwFarR-rwR)*Math.pow(lp,1.5);
      ctx.beginPath();ctx.arc(rlx,ly,2.5+la*1.5,0,Math.PI*2);
      ctx.fillStyle=`rgba(255,255,200,${.5+la})`;ctx.fill();
    }
    // Centre dashes
    for(let di=2;di<10;di++){
      const dp=di/10,dly=rwBot+(rwTop-rwBot)*Math.pow(dp,1.5);
      const dly2=rwBot+(rwTop-rwBot)*Math.pow((di+.5)/10,1.5);
      const da=.3+Math.sin(t*2+di)*.1;
      ctx.strokeStyle=`rgba(201,165,53,${da})`;ctx.lineWidth=2;
      ctx.beginPath();ctx.moveTo(cx,dly);ctx.lineTo(cx,dly2);ctx.stroke();
    }
    // Vignette
    const vig=ctx.createRadialGradient(cx,h*.5,0,cx,h*.5,Math.max(w,h)*.7);
    vig.addColorStop(0,'rgba(0,0,0,0)');vig.addColorStop(1,'rgba(4,10,20,.88)');
    ctx.fillStyle=vig;ctx.fillRect(0,0,w,h);
    const bot2=ctx.createLinearGradient(0,h*.72,0,h);
    bot2.addColorStop(0,'rgba(4,10,20,0)');bot2.addColorStop(1,'rgba(4,10,20,.97)');
    ctx.fillStyle=bot2;ctx.fillRect(0,h*.72,w,h*.28);
  }
  draw();
}

// ── CANVAS: Operator pages ────────────────────────────────────────────────────
function drawOpScene(id){
  const cId=id==='partner'?'part-canvas':'pilot-canvas';
  const c=document.getElementById(cId);if(!c)return;
  c.width=window.innerWidth;c.height=window.innerHeight;
